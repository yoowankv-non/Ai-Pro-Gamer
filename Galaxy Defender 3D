<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>Galaxy Defender 3D - Ultimate Space Shooter</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    overflow: hidden;
    background: #000;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    cursor: none;
    user-select: none;
  }
  #gameCanvas { display: block; width: 100vw; height: 100vh; }

  /* HUD */
  #hud {
    position: fixed; top: 0; left: 0; width: 100%; height: 100%;
    pointer-events: none; z-index: 10; display: none;
  }
  .hud-top {
    display: flex; justify-content: space-between;
    padding: 20px 40px; align-items: flex-start;
  }
  .hud-panel {
    background: rgba(10, 14, 39, 0.85);
    border: 1px solid rgba(0, 255, 136, 0.3);
    border-radius: 12px;
    padding: 12px 20px;
    backdrop-filter: blur(10px);
    box-shadow: 0 4px 20px rgba(0,0,0,0.5), inset 0 1px 0 rgba(255,255,255,0.1);
    transition: transform 0.3s ease;
  }
  .score-box { color: #00ff88; }
  .score-label {
    font-size: 11px; text-transform: uppercase;
    letter-spacing: 2px; opacity: 0.7; margin-bottom: 4px;
  }
  .score-value {
    font-size: 32px; font-weight: 800;
    text-shadow: 0 0 20px rgba(0,255,136,0.5);
    font-family: 'Courier New', monospace;
  }
  .level-box { color: #00ccff; text-align: center; }
  .level-value {
    font-size: 28px; font-weight: 800;
    text-shadow: 0 0 20px rgba(0,204,255,0.5);
  }
  .health-box { color: #ff5555; min-width: 220px; }
  .health-bar-container {
    width: 200px; height: 12px;
    background: rgba(0,0,0,0.5);
    border-radius: 6px; overflow: hidden;
    margin-top: 8px;
    border: 1px solid rgba(255,85,85,0.3);
    position: relative;
  }
  .health-fill {
    height: 100%;
    background: linear-gradient(90deg, #ff3333, #ff8833, #00ff88);
    border-radius: 6px;
    transition: width 0.3s cubic-bezier(0.4,0,0.2,1);
    position: relative; overflow: hidden;
  }
  .health-fill::after {
    content: ''; position: absolute; inset: 0;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
    animation: shimmer 2s infinite;
  }
  @keyframes shimmer {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(100%); }
  }
  .health-text {
    font-size: 11px; text-transform: uppercase;
    letter-spacing: 2px; opacity: 0.7;
    display: flex; justify-content: space-between;
  }

  /* Boss Health Bar */
  .boss-health {
    position: fixed; top: 110px; left: 50%;
    transform: translateX(-50%);
    width: 60%; max-width: 600px;
    display: none; z-index: 11;
  }
  .boss-health.show { display: block; }
  .boss-name {
    color: #ff3366; font-weight: 800;
    text-align: center; margin-bottom: 6px;
    text-transform: uppercase; letter-spacing: 4px;
    font-size: 14px;
    text-shadow: 0 0 15px rgba(255,51,102,0.7);
  }
  .boss-bar-container {
    width: 100%; height: 16px;
    background: rgba(0,0,0,0.7);
    border: 2px solid rgba(255,51,102,0.5);
    border-radius: 8px; overflow: hidden;
  }
  .boss-bar-fill {
    height: 100%;
    background: linear-gradient(90deg, #ff3333, #ff00ff, #ff3333);
    background-size: 200% 100%;
    animation: bossPulse 1.5s linear infinite;
    transition: width 0.3s;
  }
  @keyframes bossPulse {
    0% { background-position: 0% 0; }
    100% { background-position: 200% 0; }
  }

  /* Bottom HUD */
  .hud-bottom {
    position: absolute; bottom: 20px; left: 50%;
    transform: translateX(-50%);
    display: flex; gap: 15px;
  }
  .weapon-indicator {
    background: rgba(10,14,39,0.85);
    border: 1px solid rgba(255,221,0,0.3);
    border-radius: 8px; padding: 8px 16px;
    color: #ffdd00; font-size: 12px;
    text-transform: uppercase; letter-spacing: 1px;
    opacity: 0; transform: translateY(20px);
    transition: all 0.3s ease;
  }
  .weapon-indicator.active { opacity: 1; transform: translateY(0); }
  .weapon-indicator .timer {
    font-size: 18px; font-weight: 800; margin-top: 4px;
    font-family: 'Courier New', monospace;
  }
  #shieldIndicator { color: #00ccff; border-color: rgba(0,204,255,0.3); }
  #rapidIndicator { color: #ff00ff; border-color: rgba(255,0,255,0.3); }
  #bombIndicator { color: #ff8833; border-color: rgba(255,136,51,0.3); }

  /* Crosshair */
  #crosshair {
    position: fixed; top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 50px; height: 50px;
    pointer-events: none; z-index: 20;
    display: none;
  }
  .crosshair-ring {
    position: absolute; inset: 0;
    border: 2px solid rgba(0,255,136,0.6);
    border-radius: 50%;
    animation: crosshairPulse 1.5s ease-in-out infinite;
  }
  @keyframes crosshairPulse {
    0%, 100% { transform: scale(1); opacity: 0.6; }
    50% { transform: scale(1.1); opacity: 1; }
  }
  .crosshair-dot {
    position: absolute; width: 4px; height: 4px;
    background: #ff3333; border-radius: 50%;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    box-shadow: 0 0 10px #ff3333;
  }

  /* Start Screen */
  #startScreen {
    position: fixed; inset: 0;
    background: linear-gradient(135deg, #0a0e27 0%, #1a1f4b 50%, #0d1235 100%);
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    z-index: 100; overflow: hidden;
  }
  .stars-bg { position: absolute; inset: 0; overflow: hidden; }
  .star {
    position: absolute; background: white;
    border-radius: 50%;
    animation: twinkle 3s infinite;
  }
  @keyframes twinkle {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 1; }
  }
  .game-title {
    font-size: 72px; font-weight: 900;
    background: linear-gradient(90deg, #00ff88, #00ccff, #ff00ff, #ff8833);
    background-size: 300% 300%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: 10px; text-align: center;
    animation: gradientShift 4s ease infinite, titleFloat 3s ease-in-out infinite;
    position: relative; z-index: 2;
  }
  @keyframes gradientShift {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }
  @keyframes titleFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }
  .game-subtitle {
    font-size: 20px; color: #8892b0;
    margin-bottom: 50px; letter-spacing: 8px;
    text-transform: uppercase;
    position: relative; z-index: 2;
  }
  .start-btn {
    padding: 20px 60px; font-size: 24px;
    font-weight: 800; color: #fff;
    background: linear-gradient(135deg, #667eea, #764ba2);
    border: none; border-radius: 50px;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.4,0,0.2,1);
    box-shadow: 0 10px 30px rgba(102,126,234,0.4);
    text-transform: uppercase; letter-spacing: 4px;
    position: relative; z-index: 2; overflow: hidden;
  }
  .start-btn::before {
    content: ''; position: absolute;
    top: 0; left: -100%; width: 100%; height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
    transition: left 0.5s;
  }
  .start-btn:hover {
    transform: translateY(-5px) scale(1.05);
    box-shadow: 0 20px 40px rgba(102,126,234,0.6);
  }
  .start-btn:hover::before { left: 100%; }
  .start-btn:active { transform: translateY(-2px) scale(0.98); }

  .controls-info {
    margin-top: 50px; color: #8892b0;
    text-align: center; line-height: 2.2;
    font-size: 14px; position: relative; z-index: 2;
    background: rgba(255,255,255,0.03);
    padding: 25px 40px; border-radius: 16px;
    border: 1px solid rgba(255,255,255,0.05);
  }
  .controls-info p {
    display: flex; align-items: center;
    justify-content: center; gap: 12px;
  }
  .key-badge {
    display: inline-block;
    background: rgba(0,255,136,0.15);
    border: 1px solid rgba(0,255,136,0.3);
    color: #00ff88; padding: 4px 12px;
    border-radius: 6px; font-weight: 700;
    font-size: 12px; min-width: 80px;
    text-align: center;
    font-family: 'Courier New', monospace;
  }
  .high-score-display {
    margin-top: 20px; color: #ffdd00;
    font-size: 16px; letter-spacing: 2px;
    text-transform: uppercase;
    position: relative; z-index: 2;
  }
  .high-score-display span {
    font-family: 'Courier New', monospace;
    font-weight: 800; font-size: 22px;
    margin-left: 10px;
    text-shadow: 0 0 15px rgba(255,221,0,0.5);
  }

  /* Game Over */
  #gameOverScreen {
    position: fixed; inset: 0;
    background: rgba(0,0,0,0.92);
    display: none; flex-direction: column;
    align-items: center; justify-content: center;
    z-index: 100; backdrop-filter: blur(10px);
  }
  .game-over-title {
    font-size: 64px; color: #ff3333;
    text-shadow: 0 0 30px rgba(255,51,51,0.5);
    margin-bottom: 10px;
    animation: shake 0.5s ease-in-out;
  }
  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(-10px); }
    75% { transform: translateX(10px); }
  }
  .game-over-subtitle {
    font-size: 18px; color: #8892b0; margin-bottom: 30px;
  }
  .final-stats {
    display: flex; gap: 30px; margin-bottom: 40px;
    flex-wrap: wrap; justify-content: center;
  }
  .stat-box {
    text-align: center; padding: 20px 30px;
    background: rgba(255,255,255,0.05);
    border-radius: 12px;
    border: 1px solid rgba(255,255,255,0.1);
    min-width: 140px;
  }
  .stat-label {
    font-size: 11px; text-transform: uppercase;
    letter-spacing: 2px; color: #8892b0;
    margin-bottom: 8px;
  }
  .stat-value {
    font-size: 36px; font-weight: 800;
    font-family: 'Courier New', monospace;
  }
  .stat-value.score { color: #00ff88; text-shadow: 0 0 20px rgba(0,255,136,0.3); }
  .stat-value.level { color: #00ccff; text-shadow: 0 0 20px rgba(0,204,255,0.3); }
  .stat-value.kills { color: #ff8833; text-shadow: 0 0 20px rgba(255,136,51,0.3); }
  .stat-value.best  { color: #ffdd00; text-shadow: 0 0 20px rgba(255,221,0,0.3); }
  .new-record {
    color: #ffdd00; font-size: 20px; font-weight: 800;
    margin-bottom: 20px; letter-spacing: 4px;
    text-transform: uppercase;
    animation: pulse 1s ease-in-out infinite;
    text-shadow: 0 0 20px rgba(255,221,0,0.8);
    display: none;
  }
  .new-record.show { display: block; }
  .restart-btn {
    padding: 18px 50px; font-size: 22px;
    font-weight: 800; color: #fff;
    background: linear-gradient(135deg, #ff3333, #ff8833);
    border: none; border-radius: 50px;
    cursor: pointer; transition: all 0.3s;
    text-transform: uppercase; letter-spacing: 3px;
    box-shadow: 0 10px 30px rgba(255,51,51,0.3);
  }
  .restart-btn:hover {
    transform: scale(1.1);
    box-shadow: 0 15px 40px rgba(255,51,51,0.5);
  }

  /* Damage */
  #damageOverlay {
    position: fixed; inset: 0;
    background: radial-gradient(circle, transparent 40%, rgba(255,0,0,0.5) 100%);
    opacity: 0; transition: opacity 0.15s ease;
    pointer-events: none; z-index: 15;
  }

  /* Combo */
  .combo-display {
    position: fixed; top: 45%; left: 50%;
    transform: translate(-50%, -50%);
    font-size: 48px; font-weight: 900;
    color: #ffdd00;
    text-shadow: 0 0 30px rgba(255,221,0,0.5);
    opacity: 0; pointer-events: none; z-index: 25;
  }
  .combo-display.show { animation: comboPop 0.8s ease-out forwards; }
  @keyframes comboPop {
    0% { opacity: 0; transform: translate(-50%, -50%) scale(0.5); }
    20% { opacity: 1; transform: translate(-50%, -50%) scale(1.3); }
    100% { opacity: 0; transform: translate(-50%, -30%) scale(1); }
  }

  /* Level Up Banner */
  .levelup-banner {
    position: fixed; top: 30%; left: 50%;
    transform: translate(-50%, -50%);
    font-size: 60px; font-weight: 900;
    background: linear-gradient(90deg, #00ff88, #00ccff);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    opacity: 0; pointer-events: none; z-index: 26;
    letter-spacing: 8px;
  }
  .levelup-banner.show { animation: levelUpAnim 1.5s ease-out forwards; }
  @keyframes levelUpAnim {
    0% { opacity: 0; transform: translate(-50%, -50%) scale(0.3); }
    30% { opacity: 1; transform: translate(-50%, -50%) scale(1.1); }
    70% { opacity: 1; transform: translate(-50%, -50%) scale(1); }
    100% { opacity: 0; transform: translate(-50%, -100%) scale(1); }
  }

  /* Pause */
  #pauseOverlay {
    position: fixed; inset: 0;
    background: rgba(0,0,0,0.7);
    display: none; align-items: center; justify-content: center;
    z-index: 50; backdrop-filter: blur(5px);
    flex-direction: column; gap: 20px;
  }
  .pause-text {
    font-size: 48px; color: #fff;
    font-weight: 800; letter-spacing: 10px;
    text-transform: uppercase;
    animation: pulse 2s ease-in-out infinite;
  }
  .pause-hint {
    color: #8892b0; font-size: 14px; letter-spacing: 4px;
  }
  @keyframes pulse {
    0%, 100% { opacity: 0.5; }
    50% { opacity: 1; }
  }

  /* Floating Score */
  .floating-score {
    position: fixed; color: #00ff88;
    font-size: 20px; font-weight: 800;
    pointer-events: none; z-index: 20;
    animation: floatUp 1s ease-out forwards;
    text-shadow: 0 0 10px rgba(0,255,136,0.5);
  }
  @keyframes floatUp {
    0% { opacity: 1; transform: translateY(0) scale(1); }
    100% { opacity: 0; transform: translateY(-60px) scale(1.4); }
  }

  /* Mute button */
  #muteBtn {
    position: fixed; top: 20px; right: 20px;
    width: 44px; height: 44px;
    background: rgba(10,14,39,0.85);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 50%;
    color: #fff; font-size: 20px;
    cursor: pointer; z-index: 200;
    display: none; align-items: center; justify-content: center;
    transition: all 0.3s;
  }
  #muteBtn:hover { transform: scale(1.1); }
  #muteBtn.visible { display: flex; }

  /* Bomb flash */
  #bombFlash {
    position: fixed; inset: 0;
    background: rgba(255,255,255,0.9);
    opacity: 0; pointer-events: none;
    z-index: 30; transition: opacity 0.4s;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .game-title { font-size: 42px; }
    .game-subtitle { font-size: 14px; letter-spacing: 4px; }
    .start-btn { padding: 15px 40px; font-size: 18px; }
    .controls-info { padding: 15px 20px; font-size: 12px; }
    .hud-top { padding: 10px 20px; flex-wrap: wrap; gap: 10px; }
    .score-value { font-size: 24px; }
    .health-bar-container { width: 130px; }
    .game-over-title { font-size: 42px; }
    .stat-box { padding: 12px 18px; min-width: 100px; }
    .stat-value { font-size: 24px; }
    .combo-display { font-size: 32px; }
    .levelup-banner { font-size: 36px; letter-spacing: 4px; }
  }
</style>
</head>
<body>

<canvas id="gameCanvas"></canvas>

<!-- Start Screen -->
<div id="startScreen">
  <div class="stars-bg" id="starsBg"></div>
  <h1 class="game-title">GALAXY DEFENDER</h1>
  <p class="game-subtitle">3D Space Shooter • Ultimate Edition</p>
  <button id="startBtn" class="start-btn">START MISSION</button>
  <div class="high-score-display">High Score: <span id="highScoreDisplay">0</span></div>
  <div class="controls-info">
    <p><span class="key-badge">MOUSE</span> Aim &amp; Auto-fire</p>
    <p><span class="key-badge">WASD</span> Move Ship</p>
    <p><span class="key-badge">SPACE</span> Boost Speed</p>
    <p><span class="key-badge">B</span> Smart Bomb (clears screen)</p>
    <p><span class="key-badge">P / ESC</span> Pause Game</p>
    <p><span class="key-badge">M</span> Mute Sound</p>
  </div>
</div>

<!-- HUD -->
<div id="hud">
  <div class="hud-top">
    <div class="hud-panel score-box">
      <div class="score-label">Score</div>
      <div class="score-value"><span id="score">0</span></div>
    </div>
    <div class="hud-panel level-box">
      <div class="score-label">Level</div>
      <div class="level-value"><span id="level">1</span></div>
    </div>
    <div class="hud-panel health-box">
      <div class="health-text">
        <span>Shield Integrity</span>
        <span id="healthPercent">100%</span>
      </div>
      <div class="health-bar-container">
        <div class="health-fill" id="healthFill" style="width:100%"></div>
      </div>
    </div>
  </div>

  <div class="boss-health" id="bossHealth">
    <div class="boss-name" id="bossName">⚠ BOSS INCOMING ⚠</div>
    <div class="boss-bar-container">
      <div class="boss-bar-fill" id="bossBarFill" style="width:100%"></div>
    </div>
  </div>

  <div class="hud-bottom">
    <div class="weapon-indicator" id="tripleShotIndicator">
      ⚡ Triple Shot
      <div class="timer"><span id="tripleShotTimer">0</span>s</div>
    </div>
    <div class="weapon-indicator" id="shieldIndicator">
      🛡 Shield Active
      <div class="timer"><span id="shieldTimer">0</span>s</div>
    </div>
    <div class="weapon-indicator" id="rapidIndicator">
      🔥 Rapid Fire
      <div class="timer"><span id="rapidTimer">0</span>s</div>
    </div>
    <div class="weapon-indicator active" id="bombIndicator">
      💣 Bombs
      <div class="timer"><span id="bombCount">3</span></div>
    </div>
  </div>
</div>

<!-- Crosshair -->
<div id="crosshair">
  <div class="crosshair-ring"></div>
  <div class="crosshair-dot"></div>
</div>

<!-- Game Over -->
<div id="gameOverScreen">
  <h1 class="game-over-title">MISSION FAILED</h1>
  <p class="game-over-subtitle">Your ship has been destroyed</p>
  <div class="new-record" id="newRecord">★ NEW HIGH SCORE ★</div>
  <div class="final-stats">
    <div class="stat-box">
      <div class="stat-label">Final Score</div>
      <div class="stat-value score" id="finalScore">0</div>
    </div>
    <div class="stat-box">
      <div class="stat-label">Level</div>
      <div class="stat-value level" id="finalLevel">1</div>
    </div>
    <div class="stat-box">
      <div class="stat-label">Kills</div>
      <div class="stat-value kills" id="finalKills">0</div>
    </div>
    <div class="stat-box">
      <div class="stat-label">Best</div>
      <div class="stat-value best" id="finalBest">0</div>
    </div>
  </div>
  <button id="restartBtn" class="restart-btn">RETRY MISSION</button>
</div>

<!-- Effects -->
<div id="damageOverlay"></div>
<div id="bombFlash"></div>
<div class="combo-display" id="comboDisplay">COMBO x3!</div>
<div class="levelup-banner" id="levelupBanner">LEVEL UP!</div>

<!-- Pause -->
<div id="pauseOverlay">
  <div class="pause-text">PAUSED</div>
  <div class="pause-hint">Press P or ESC to resume</div>
</div>

<!-- Mute -->
<button id="muteBtn" title="Mute (M)">🔊</button>

<script>
/* ==================== AUDIO ENGINE ==================== */
const AudioEngine = {
  ctx: null, initialized: false, muted: false, masterGain: null,
  init() {
    if (this.initialized) return;
    this.ctx = new (window.AudioContext || window.webkitAudioContext)();
    this.masterGain = this.ctx.createGain();
    this.masterGain.gain.value = 1;
    this.masterGain.connect(this.ctx.destination);
    this.initialized = true;
  },
  toggleMute() {
    this.muted = !this.muted;
    if (this.masterGain) {
      this.masterGain.gain.setValueAtTime(this.muted ? 0 : 1, this.ctx.currentTime);
    }
    return this.muted;
  },
  playTone(freq, duration, type = 'sine', volume = 0.1) {
    if (!this.ctx || this.muted) return;
    const osc = this.ctx.createOscillator();
    const gain = this.ctx.createGain();
    osc.type = type;
    osc.frequency.setValueAtTime(freq, this.ctx.currentTime);
    gain.gain.setValueAtTime(volume, this.ctx.currentTime);
    gain.gain.exponentialRampToValueAtTime(0.01, this.ctx.currentTime + duration);
    osc.connect(gain); gain.connect(this.masterGain);
    osc.start(); osc.stop(this.ctx.currentTime + duration);
  },
  playShoot() {
    if (!this.ctx || this.muted) return;
    const osc = this.ctx.createOscillator();
    const gain = this.ctx.createGain();
    osc.type = 'sawtooth';
    osc.frequency.setValueAtTime(800, this.ctx.currentTime);
    osc.frequency.exponentialRampToValueAtTime(200, this.ctx.currentTime + 0.12);
    gain.gain.setValueAtTime(0.06, this.ctx.currentTime);
    gain.gain.exponentialRampToValueAtTime(0.01, this.ctx.currentTime + 0.12);
    osc.connect(gain); gain.connect(this.masterGain);
    osc.start(); osc.stop(this.ctx.currentTime + 0.12);
  },
  playTripleShot() {
    [600, 800, 1000].forEach((f, i) =>
      setTimeout(() => this.playTone(f, 0.1, 'square', 0.05), i * 25));
  },
  playExplosion(big = false) {
    if (!this.ctx || this.muted) return;
    const dur = big ? 0.6 : 0.3;
    const bufferSize = this.ctx.sampleRate * dur;
    const buffer = this.ctx.createBuffer(1, bufferSize, this.ctx.sampleRate);
    const data = buffer.getChannelData(0);
    for (let i = 0; i < bufferSize; i++) {
      data[i] = (Math.random() * 2 - 1) * Math.pow(1 - i / bufferSize, 2);
    }
    const source = this.ctx.createBufferSource();
    const gain = this.ctx.createGain();
    const filter = this.ctx.createBiquadFilter();
    source.buffer = buffer;
    filter.type = 'lowpass';
    filter.frequency.setValueAtTime(big ? 1500 : 1000, this.ctx.currentTime);
    filter.frequency.exponentialRampToValueAtTime(80, this.ctx.currentTime + dur);
    gain.gain.setValueAtTime(big ? 0.25 : 0.15, this.ctx.currentTime);
    gain.gain.exponentialRampToValueAtTime(0.01, this.ctx.currentTime + dur);
    source.connect(filter); filter.connect(gain); gain.connect(this.masterGain);
    source.start();
  },
  playPowerUp() {
    [400, 600, 800, 1000, 1200].forEach((f, i) =>
      setTimeout(() => this.playTone(f, 0.15, 'sine', 0.08), i * 70));
  },
  playHit() {
    if (!this.ctx || this.muted) return;
    const osc = this.ctx.createOscillator();
    const gain = this.ctx.createGain();
    osc.type = 'square';
    osc.frequency.setValueAtTime(200, this.ctx.currentTime);
    osc.frequency.exponentialRampToValueAtTime(50, this.ctx.currentTime + 0.2);
    gain.gain.setValueAtTime(0.1, this.ctx.currentTime);
    gain.gain.exponentialRampToValueAtTime(0.01, this.ctx.currentTime + 0.2);
    osc.connect(gain); gain.connect(this.masterGain);
    osc.start(); osc.stop(this.ctx.currentTime + 0.2);
  },
  playLevelUp() {
    [523, 659, 784, 1047, 1319].forEach((f, i) =>
      setTimeout(() => this.playTone(f, 0.3, 'sine', 0.09), i * 130));
  },
  playBomb() {
    if (!this.ctx || this.muted) return;
    this.playExplosion(true);
    setTimeout(() => this.playExplosion(true), 150);
  },
  playBossWarn() {
    [200, 200, 200].forEach((f, i) =>
      setTimeout(() => this.playTone(f, 0.2, 'sawtooth', 0.12), i * 250));
  },
  playAmbient() {
    if (!this.ctx) return null;
    const osc = this.ctx.createOscillator();
    const gain = this.ctx.createGain();
    osc.type = 'sine';
    osc.frequency.setValueAtTime(60, this.ctx.currentTime);
    const lfo = this.ctx.createOscillator();
    const lfoGain = this.ctx.createGain();
    lfo.frequency.setValueAtTime(0.1, this.ctx.currentTime);
    lfoGain.gain.setValueAtTime(10, this.ctx.currentTime);
    lfo.connect(lfoGain); lfoGain.connect(osc.frequency);
    lfo.start();
    gain.gain.setValueAtTime(0.02, this.ctx.currentTime);
    osc.connect(gain); gain.connect(this.masterGain);
    osc.start();
    return { osc, gain, lfo, lfoGain };
  }
};

