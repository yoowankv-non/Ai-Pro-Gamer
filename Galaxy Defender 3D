    star.style.width = star.style.height = s + 'px';
    container.appendChild(star);
  }
}

/* ==================== DRAWING ==================== */
function drawStars() {
  for (const star of stars) {
    star.z -= star.speed + (level * 0.4);
    if (star.z < 1) {
      star.z = 2000;
      star.x = (Math.random() - 0.5) * 3000;
      star.y = (Math.random() - 0.5) * 3000;
    }
    const p = project(star.x, star.y, star.z);
    const alpha = Math.min(1, (2000 - star.z) / 400) * star.brightness;
    const size = star.size * p.scale;

    ctx.beginPath();
    ctx.arc(p.x, p.y, size * 2, 0, Math.PI * 2);
    ctx.fillStyle = `rgba(200,220,255,${alpha * 0.25})`;
    ctx.fill();

    ctx.beginPath();
    ctx.arc(p.x, p.y, size, 0, Math.PI * 2);
    ctx.fillStyle = star.color === 'rgba(255,255,255,1)'
      ? `rgba(255,255,255,${alpha})`
      : star.color.replace(')', `, ${alpha})`).replace('hsl', 'hsla');
    ctx.fill();

    if (star.z < 1000) {
      const trailLength = (25 + star.speed * 10) * p.scale;
      const gradient = ctx.createLinearGradient(p.x, p.y, p.x, p.y + trailLength);
      gradient.addColorStop(0, `rgba(200,220,255,${alpha * 0.6})`);
      gradient.addColorStop(1, 'transparent');
      ctx.beginPath();
      ctx.moveTo(p.x, p.y);
      ctx.lineTo(p.x, p.y + trailLength);
      ctx.strokeStyle = gradient;
      ctx.lineWidth = size;
      ctx.lineCap = 'round';
      ctx.stroke();
    }
  }
}

function drawPlayer() {
  if (player.invulnerable > 0 && !shieldActive && Math.floor(frameCount / 3) % 2 === 0) return;

  player.x += (player.targetX - player.x) * 0.18;
  player.y += (player.targetY - player.y) * 0.18;
  player.tilt += ((player.targetX - player.x) * 0.02 - player.tilt) * 0.15;

  const p = project(player.x, player.y, player.z);
  const size = player.size * p.scale;

  ctx.save();
  ctx.translate(p.x, p.y);
  ctx.rotate(player.tilt * 0.3);

  // Engine flames
  const flameHeight = size * (0.8 + Math.random() * 0.4);
  const flameWidth = size * 0.3;
  ctx.beginPath();
  ctx.moveTo(-flameWidth, size * 0.5);
  ctx.quadraticCurveTo(-flameWidth * 0.5, size * 0.5 + flameHeight * 0.5, 0, size * 0.5 + flameHeight);
  ctx.quadraticCurveTo(flameWidth * 0.5, size * 0.5 + flameHeight * 0.5, flameWidth, size * 0.5);
  ctx.closePath();
  const flameGradient = ctx.createLinearGradient(0, size * 0.5, 0, size * 0.5 + flameHeight);
  flameGradient.addColorStop(0, 'rgba(255,100,0,0.9)');
  flameGradient.addColorStop(0.5, 'rgba(255,200,0,0.6)');
  flameGradient.addColorStop(1, 'rgba(255,255,0,0)');
  ctx.fillStyle = flameGradient;
  ctx.fill();

  ctx.beginPath();
  ctx.moveTo(-flameWidth * 0.5, size * 0.5);
  ctx.lineTo(0, size * 0.5 + flameHeight * 0.7);
  ctx.lineTo(flameWidth * 0.5, size * 0.5);
  ctx.closePath();
  ctx.fillStyle = 'rgba(255,255,200,0.85)';
  ctx.fill();

  ctx.shadowBlur = 25;
  ctx.shadowColor = '#00ff88';

  // Ship body
  ctx.beginPath();
  ctx.moveTo(0, -size * 1.8);
  ctx.lineTo(-size * 0.8, -size * 0.3);
  ctx.lineTo(-size * 1.2, size * 0.8);
  ctx.lineTo(-size * 0.4, size * 0.5);
  ctx.lineTo(0, size * 0.2);
  ctx.lineTo(size * 0.4, size * 0.5);
  ctx.lineTo(size * 1.2, size * 0.8);
  ctx.lineTo(size * 0.8, -size * 0.3);
  ctx.closePath();
  const shipGradient = ctx.createLinearGradient(0, -size * 1.8, 0, size);
  shipGradient.addColorStop(0, '#00ff88');
  shipGradient.addColorStop(0.5, '#00cc66');
  shipGradient.addColorStop(1, '#006633');
  ctx.fillStyle = shipGradient;
  ctx.fill();

  // Highlight stripe
  ctx.beginPath();
  ctx.moveTo(0, -size * 1.6);
  ctx.lineTo(-size * 0.1, size * 0.3);
  ctx.lineTo(size * 0.1, size * 0.3);
  ctx.closePath();
  ctx.fillStyle = 'rgba(255,255,255,0.4)';
  ctx.fill();

  // Cockpit
  ctx.beginPath();
  ctx.ellipse(0, -size * 0.3, size * 0.35, size * 0.5, 0, 0, Math.PI * 2);
  ctx.fillStyle = '#00ccff';
  ctx.fill();
  ctx.beginPath();
  ctx.ellipse(0, -size * 0.4, size * 0.2, size * 0.3, 0, 0, Math.PI * 2);
  ctx.fillStyle = '#ffffff';
  ctx.fill();

  // Wing details
  ctx.strokeStyle = 'rgba(0,255,136,0.6)';
  ctx.lineWidth = 1.5;
  ctx.beginPath();
  ctx.moveTo(-size * 0.8, -size * 0.3);
  ctx.lineTo(-size * 0.3, size * 0.3);
  ctx.moveTo(size * 0.8, -size * 0.3);
  ctx.lineTo(size * 0.3, size * 0.3);
  ctx.stroke();

  // Shield bubble
  if (shieldActive) {
    const shieldPulse = 0.5 + Math.sin(frameCount * 0.15) * 0.2;
    ctx.beginPath();
    ctx.arc(0, 0, size * 2.2, 0, Math.PI * 2);
    const shieldGrad = ctx.createRadialGradient(0, 0, size * 1.5, 0, 0, size * 2.2);
    shieldGrad.addColorStop(0, 'rgba(0,204,255,0)');
    shieldGrad.addColorStop(0.7, `rgba(0,204,255,${shieldPulse * 0.3})`);
    shieldGrad.addColorStop(1, `rgba(0,204,255,${shieldPulse * 0.6})`);
    ctx.fillStyle = shieldGrad;
    ctx.fill();
    ctx.strokeStyle = `rgba(0,204,255,${shieldPulse})`;
    ctx.lineWidth = 2;
    ctx.stroke();
  } else if (player.invulnerable > 0) {
    ctx.beginPath();
    ctx.arc(0, 0, size * 2, 0, Math.PI * 2);
    ctx.strokeStyle = `rgba(255,255,255,${0.3 + Math.sin(frameCount * 0.3) * 0.2})`;
    ctx.lineWidth = 2;
    ctx.stroke();
  }

  ctx.restore();
}

function drawEnemy(enemy) {
  const p = project(enemy.x, enemy.y, enemy.z);
  const size = enemy.size * p.scale;
  const pulse = 1 + Math.sin(frameCount * 0.1 + enemy.id) * 0.1;

  ctx.save();
  ctx.translate(p.x, p.y);
  ctx.rotate(enemy.rotation || 0);
  ctx.scale(pulse, pulse);

  ctx.shadowBlur = 20;
  ctx.shadowColor = enemy.color;

  if (enemy.type === 'chaser') {
    ctx.beginPath();
    ctx.moveTo(0, -size);
    ctx.lineTo(size, 0);
    ctx.lineTo(0, size);
    ctx.lineTo(-size, 0);
    ctx.closePath();
  } else if (enemy.type === 'tank') {
    ctx.beginPath();
    for (let i = 0; i < 6; i++) {
      const angle = (i / 6) * Math.PI * 2 - Math.PI / 2;
      const x = Math.cos(angle) * size;
      const y = Math.sin(angle) * size;
      if (i === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);
    }
    ctx.closePath();
  } else if (enemy.type === 'speeder') {
    ctx.beginPath();
    ctx.moveTo(0, size);
    ctx.lineTo(-size * 0.6, -size * 0.5);
    ctx.lineTo(0, -size);
    ctx.lineTo(size * 0.6, -size * 0.5);
    ctx.closePath();
  } else if (enemy.type === 'shooter') {
    // Triangle with gun
    ctx.beginPath();
    ctx.moveTo(0, size);
    ctx.lineTo(-size, -size * 0.5);
    ctx.lineTo(size, -size * 0.5);
    ctx.closePath();
  } else if (enemy.type === 'boss') {
    // Big complex shape
    ctx.beginPath();
    for (let i = 0; i < 10; i++) {
      const angle = (i / 10) * Math.PI * 2;
      const r = i % 2 === 0 ? size : size * 0.65;
      const x = Math.cos(angle) * r;
      const y = Math.sin(angle) * r;
      if (i === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);
    }
    ctx.closePath();
  } else {
    ctx.beginPath();
    for (let i = 0; i < 8; i++) {
      const angle = (i / 8) * Math.PI * 2;
      const r = i % 2 === 0 ? size : size * 0.6;
      const x = Math.cos(angle) * r;
      const y = Math.sin(angle) * r;
      if (i === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);
    }
    ctx.closePath();
  }

  const grad = ctx.createRadialGradient(0, 0, size * 0.2, 0, 0, size);
  grad.addColorStop(0, '#ffffff');
  grad.addColorStop(0.4, enemy.color);
  grad.addColorStop(1, enemy.color);
  ctx.fillStyle = grad;
  ctx.fill();

  ctx.strokeStyle = 'rgba(0,0,0,0.4)';
  ctx.lineWidth = 1;
  ctx.stroke();

  // Core
  ctx.beginPath();
  ctx.arc(0, 0, size * 0.35, 0, Math.PI * 2);
  ctx.fillStyle = '#fff';
  ctx.fill();

  ctx.beginPath();
  ctx.arc(0, 0, size * 0.18, 0, Math.PI * 2);
  ctx.fillStyle = enemy.color;
  ctx.fill();

  // Hit flash
  if (enemy.hitFlash > 0) {
    ctx.beginPath();
    if (enemy.type === 'boss') {
      ctx.arc(0, 0, size * 1.1, 0, Math.PI * 2);
    } else {
      ctx.arc(0, 0, size * 1.05, 0, Math.PI * 2);
    }
    ctx.fillStyle = `rgba(255,255,255,${enemy.hitFlash / 10})`;
    ctx.fill();
    enemy.hitFlash--;
  }

  ctx.restore();

  // Health bar for tough enemies (not boss - boss has its own bar)
  if (enemy.maxHealth > 1 && enemy.type !== 'boss') {
    const barWidth = enemy.size * p.scale * 1.5;
    const barHeight = 3;
    const healthPercent = enemy.health / enemy.maxHealth;
    ctx.fillStyle = 'rgba(0,0,0,0.6)';
    ctx.fillRect(p.x - barWidth / 2, p.y - enemy.size * p.scale - 10, barWidth, barHeight);
    ctx.fillStyle = healthPercent > 0.5 ? '#00ff88' : healthPercent > 0.25 ? '#ffdd00' : '#ff3333';
    ctx.fillRect(p.x - barWidth / 2, p.y - enemy.size * p.scale - 10, barWidth * healthPercent, barHeight);
  }
}

function drawBullet(bullet) {
  const p = project(bullet.x, bullet.y, bullet.z);
  const size = 3 * p.scale;

  ctx.save();
  ctx.shadowBlur = 15;
  ctx.shadowColor = bullet.color;

  const trailLength = 18 * p.scale;
  const gradient = ctx.createLinearGradient(p.x, p.y, p.x, p.y + trailLength);
  gradient.addColorStop(0, bullet.color);
  gradient.addColorStop(1, 'transparent');

  ctx.beginPath();
  ctx.moveTo(p.x, p.y);
  ctx.lineTo(p.x - bullet.vx * 2, p.y + trailLength);
  ctx.strokeStyle = gradient;
  ctx.lineWidth = size * 2.2;
  ctx.lineCap = 'round';
  ctx.stroke();

  ctx.beginPath();
  ctx.arc(p.x, p.y, size, 0, Math.PI * 2);
  ctx.fillStyle = '#ffffff';
  ctx.fill();
  ctx.restore();
}

function drawEnemyBullet(b) {
  const p = project(b.x, b.y, b.z);
  const size = 4 * p.scale;
  ctx.save();
  ctx.shadowBlur = 12;
  ctx.shadowColor = '#ff3366';
  ctx.beginPath();
  ctx.arc(p.x, p.y, size, 0, Math.PI * 2);
  ctx.fillStyle = '#ff3366';
  ctx.fill();
  ctx.beginPath();
  ctx.arc(p.x, p.y, size * 0.5, 0, Math.PI * 2);
  ctx.fillStyle = '#fff';
  ctx.fill();
  ctx.restore();
}

function drawPowerup(powerup) {
  const p = project(powerup.x, powerup.y, powerup.z);
  const size = 18 * p.scale;
  const rotation = frameCount * 0.03;
  const bob = Math.sin(frameCount * 0.05) * 5;

  ctx.save();
  ctx.translate(p.x, p.y + bob);
  ctx.rotate(rotation);

  ctx.shadowBlur = 25;
  ctx.shadowColor = powerup.color;

  ctx.beginPath();
  ctx.arc(0, 0, size * 1.3, 0, Math.PI * 2);
  ctx.strokeStyle = powerup.color;
  ctx.lineWidth = 2;
  ctx.setLineDash([5, 5]);
  ctx.stroke();
  ctx.setLineDash([]);

  ctx.fillStyle = powerup.color;
  ctx.globalAlpha = 0.3;
  ctx.fillRect(-size, -size, size * 2, size * 2);
  ctx.globalAlpha = 1;

  ctx.rotate(-rotation);
  ctx.fillStyle = '#fff';
  ctx.font = `bold ${size * 1.2}px Arial`;
  ctx.textAlign = 'center';
  ctx.textBaseline = 'middle';
  ctx.fillText(powerup.symbol, 0, 0);

  ctx.restore();
}

function createExplosion(x, y, z, color, count = 20) {
  for (let i = 0; i < count; i++) {
    const angle = Math.random() * Math.PI * 2;
    const speed = Math.random() * 8 + 2;
    explosions.push({
      x, y, z,
      vx: Math.cos(angle) * speed,
      vy: Math.sin(angle) * speed,
      vz: (Math.random() - 0.5) * 5,
      life: 40, maxLife: 40,
      color,
      size: Math.random() * 6 + 2,
      type: Math.random() > 0.5 ? 'particle' : 'spark'
    });
  }
}

function createShockwave(x, y, z, color, maxSize = 200) {
  shockwaves.push({ x, y, z, life: 30, maxLife: 30, color, maxSize });
}

function drawShockwaves() {
  shockwaves = shockwaves.filter(s => s.life > 0);
  shockwaves.forEach(s => {
    s.life--;
    const progress = 1 - s.life / s.maxLife;
    const p = project(s.x, s.y, s.z);
    const radius = s.maxSize * progress * p.scale;
    ctx.save();
    ctx.beginPath();
    ctx.arc(p.x, p.y, radius, 0, Math.PI * 2);
    ctx.strokeStyle = s.color;
    ctx.globalAlpha = (1 - progress) * 0.8;
    ctx.lineWidth = 4 * (1 - progress) + 1;
    ctx.stroke();
    ctx.restore();
  });
}

function drawExplosions() {
  explosions = explosions.filter(exp => exp.life > 0);
  explosions.forEach(exp => {
    exp.x += exp.vx; exp.y += exp.vy; exp.z += exp.vz;
    exp.vx *= 0.95; exp.vy *= 0.95;
    exp.life--;
    const p = project(exp.x, exp.y, exp.z);
    const alpha = exp.life / exp.maxLife;
    const size = exp.size * p.scale * alpha;

    if (exp.type === 'particle') {
      ctx.save();
      ctx.shadowBlur = 10;
      ctx.shadowColor = exp.color;
      ctx.beginPath();
      ctx.arc(p.x, p.y, size, 0, Math.PI * 2);
      ctx.fillStyle = exp.color;
      ctx.globalAlpha = alpha;
      ctx.fill();
      ctx.restore();
    } else {
      ctx.save();
      ctx.translate(p.x, p.y);
      ctx.rotate(Math.atan2(exp.vy, exp.vx));
      ctx.fillStyle = exp.color;
      ctx.globalAlpha = alpha;
      ctx.fillRect(-size * 2, -size * 0.3, size * 4, size * 0.6);
      ctx.restore();
    }
  });
}

function createFloatingScore(x, y, points, color = '#00ff88') {
  const el = document.createElement('div');
  el.className = 'floating-score';
  el.textContent = typeof points === 'number' ? `+${points}` : points;
