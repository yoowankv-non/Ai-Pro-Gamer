/* ==================== GAME LOGIC ==================== */
function spawnEnemy() {
  const baseTypes = [
    { type: 'chaser',  color: '#ff3333', size: 18, speed: 2.5, health: 1, score: 100 },
    { type: 'tank',    color: '#ff8833', size: 28, speed: 1.2, health: 3, score: 250 },
    { type: 'speeder', color: '#ff00ff', size: 14, speed: 4.0, health: 1, score: 200 },
    { type: 'shooter', color: '#ffaa00', size: 22, speed: 1.5, health: 2, score: 350 }
  ];
  const pool = baseTypes.slice(0, Math.min(level, baseTypes.length));
  const t = pool[Math.floor(Math.random() * pool.length)];

  enemies.push({
    id: Math.random(),
    x: (Math.random() - 0.5) * 800,
    y: -350 - Math.random() * 200,
    z: Math.random() * 100 - 50,
    vx: 0,
    vy: t.speed + (level * 0.15),
    size: t.size,
    color: t.color,
    health: t.health,
    maxHealth: t.health,
    score: t.score,
    type: t.type,
    angle: Math.random() * Math.PI * 2,
    wobbleSpeed: Math.random() * 0.03 + 0.01,
    rotation: 0,
    rotSpeed: (Math.random() - 0.5) * 0.05,
    hitFlash: 0,
    shootCooldown: 60 + Math.random() * 60
  });
}

function spawnBoss() {
  AudioEngine.playBossWarn();
  const bossSize = 50 + level * 4;
  const bossHealth = 15 + level * 6;
  const boss = {
    id: Math.random(),
    x: 0, y: -400, z: 0,
    vx: 0, vy: 1,
    size: bossSize,
    color: '#ff2266',
    health: bossHealth,
    maxHealth: bossHealth,
    score: 2000 + level * 500,
    type: 'boss',
    angle: 0,
    wobbleSpeed: 0.02,
    rotation: 0,
    rotSpeed: 0.01,
    hitFlash: 0,
    shootCooldown: 90,
    isBoss: true,
    entered: false
  };
  enemies.push(boss);
  activeBoss = boss;
  document.getElementById('bossHealth').classList.add('show');
  document.getElementById('bossName').textContent = `⚠ LEVEL ${level} BOSS ⚠`;
}

function spawnPowerup() {
  const types = [
    { color: '#ffdd00', symbol: '⚡', type: 'triple',  duration: 480 },
    { color: '#00ff88', symbol: '♥', type: 'health',  duration: 0 },
    { color: '#00ccff', symbol: '🛡', type: 'shield',  duration: 420 },
    { color: '#ff00ff', symbol: '🔥', type: 'rapid',   duration: 360 },
    { color: '#ff8833', symbol: '💣', type: 'bomb',    duration: 0 }
  ];
  const t = types[Math.floor(Math.random() * types.length)];
  powerups.push({
    x: (Math.random() - 0.5) * 600,
    y: -300, z: 0, vy: 1.8,
    ...t
  });
}

function shoot() {
  const fireRate = rapidFireActive ? 3 : 8;
  if (frameCount % fireRate !== 0) return;

  if (tripleShotActive) {
    AudioEngine.playTripleShot();
    bullets.push(
      { x: player.x,      y: player.y - 20, z: 0, vx: 0,  vy: -18, speed: 18, color: '#00ff88', damage: 1 },
      { x: player.x - 20, y: player.y - 10, z: 0, vx: -3, vy: -16, speed: 16, color: '#00ccff', damage: 1 },
      { x: player.x + 20, y: player.y - 10, z: 0, vx: 3,  vy: -16, speed: 16, color: '#00ccff', damage: 1 }
    );
  } else {
    AudioEngine.playShoot();
    bullets.push({
      x: player.x, y: player.y - 20, z: 0,
      vx: 0, vy: -18, speed: 18,
      color: rapidFireActive ? '#ff00ff' : '#00ff88',
      damage: 1
    });
  }
}

function enemyShoot(enemy) {
  const dx = player.x - enemy.x;
  const dy = player.y - enemy.y;
  const dist = Math.sqrt(dx * dx + dy * dy) || 1;
  const speed = 7;
  enemyBullets.push({
    x: enemy.x, y: enemy.y, z: enemy.z,
    vx: (dx / dist) * speed,
    vy: (dy / dist) * speed,
    life: 200
  });
}

function bossShoot(boss) {
  // Spread shot
  AudioEngine.playTone(300, 0.1, 'square', 0.06);
  const baseAngle = Math.atan2(player.y - boss.y, player.x - boss.x);
  const spread = 5;
  for (let i = -2; i <= 2; i++) {
    const a = baseAngle + i * 0.15;
    enemyBullets.push({
      x: boss.x, y: boss.y, z: boss.z,
      vx: Math.cos(a) * 6,
      vy: Math.sin(a) * 6,
      life: 200
    });
  }
}

function applyPowerup(powerup) {
  AudioEngine.playPowerUp();
  if (powerup.type === 'triple') {
    tripleShotActive = true;
    tripleShotTimer = powerup.duration;
    document.getElementById('tripleShotIndicator').classList.add('active');
  } else if (powerup.type === 'health') {
    health = Math.min(maxHealth, health + 35);
    createFloatingScore(canvas.width / 2, canvas.height / 2, '+HEALTH', '#00ff88');
  } else if (powerup.type === 'shield') {
    shieldActive = true;
    shieldTimer = powerup.duration;
    player.invulnerable = powerup.duration;
    document.getElementById('shieldIndicator').classList.add('active');
  } else if (powerup.type === 'rapid') {
    rapidFireActive = true;
    rapidFireTimer = powerup.duration;
    document.getElementById('rapidIndicator').classList.add('active');
  } else if (powerup.type === 'bomb') {
    bombs = Math.min(bombs + 1, 9);
    document.getElementById('bombCount').textContent = bombs;
    createFloatingScore(canvas.width / 2, canvas.height / 2, '+BOMB', '#ff8833');
  }
}

function useBomb() {
  if (bombs <= 0 || !gameRunning || gamePaused) return;
  bombs--;
  document.getElementById('bombCount').textContent = bombs;
  AudioEngine.playBomb();

  // Visual flash
  const flash = document.getElementById('bombFlash');
  flash.style.opacity = '1';
  setTimeout(() => flash.style.opacity = '0', 100);

  screenShake = 25;

  // Damage all on-screen enemies
  for (let i = enemies.length - 1; i >= 0; i--) {
    const e = enemies[i];
    const dmg = e.isBoss ? 5 : 99;
    e.health -= dmg;
    e.hitFlash = 8;
    createExplosion(e.x, e.y, e.z, e.color, 15);
    if (e.health <= 0) {
      AudioEngine.playExplosion(e.isBoss);
      createExplosion(e.x, e.y, e.z, e.color, e.isBoss ? 60 : 25);
      createShockwave(e.x, e.y, e.z, e.color, e.isBoss ? 400 : 200);
      score += e.score;
      kills++;
      if (e.isBoss) {
        activeBoss = null;
        document.getElementById('bossHealth').classList.remove('show');
      }
      enemies.splice(i, 1);
    }
  }

  // Clear enemy bullets
  enemyBullets = [];
  createShockwave(player.x, player.y, 0, '#ff8833', 800);
}

function showDamage() {
  const overlay = document.getElementById('damageOverlay');
  overlay.style.opacity = '1';
  setTimeout(() => overlay.style.opacity = '0', 200);
}

/* ==================== UPDATE ==================== */
function update() {
  if (!gameRunning || gamePaused) return;
  frameCount++;

  // Screen shake decay
  if (screenShake > 0) {
    screenShakeX = (Math.random() - 0.5) * screenShake;
    screenShakeY = (Math.random() - 0.5) * screenShake;
    screenShake *= 0.88;
    if (screenShake < 0.5) { screenShake = 0; screenShakeX = 0; screenShakeY = 0; }
  }

  // Movement
  const speed = keys[' '] ? player.boostSpeed : player.speed;
  if (keys['w'] || keys['arrowup'])    player.targetY -= speed;
  if (keys['s'] || keys['arrowdown'])  player.targetY += speed;
  if (keys['a'] || keys['arrowleft'])  player.targetX -= speed;
  if (keys['d'] || keys['arrowright']) player.targetX += speed;

  player.targetX = Math.max(-380, Math.min(380, player.targetX));
  player.targetY = Math.max(-260, Math.min(260, player.targetY));

  if (player.invulnerable > 0) player.invulnerable--;

  // Power-up timers
  if (tripleShotActive) {
    tripleShotTimer--;
    document.getElementById('tripleShotTimer').textContent = Math.ceil(tripleShotTimer / 60);
    if (tripleShotTimer <= 0) {
      tripleShotActive = false;
      document.getElementById('tripleShotIndicator').classList.remove('active');
    }
  }
  if (shieldActive) {
    shieldTimer--;
    document.getElementById('shieldTimer').textContent = Math.ceil(shieldTimer / 60);
    if (shieldTimer <= 0) {
      shieldActive = false;
      document.getElementById('shieldIndicator').classList.remove('active');
    }
  }
  if (rapidFireActive) {
    rapidFireTimer--;
    document.getElementById('rapidTimer').textContent = Math.ceil(rapidFireTimer / 60);
    if (rapidFireTimer <= 0) {
      rapidFireActive = false;
      document.getElementById('rapidIndicator').classList.remove('active');
    }
  }

  // Auto-shoot
  if (mouseDown) shoot();

  // Update bullets
  bullets = bullets.filter(b => b.y > -450 && b.x > -1000 && b.x < 1000);
  bullets.forEach(b => { b.y -= b.speed; b.x += b.vx; });

  // Enemy bullets
  enemyBullets = enemyBullets.filter(b => b.life > 0 && Math.abs(b.x) < 1500 && Math.abs(b.y) < 1500);
  enemyBullets.forEach(b => {
    b.x += b.vx; b.y += b.vy; b.life--;
  });

  // Update enemies
  enemies = enemies.filter(e => e.y < 450 || e.isBoss);
  enemies.forEach(e => {
    e.angle += e.wobbleSpeed;
    e.rotation += e.rotSpeed;

    if (e.isBoss) {
      // Boss movement: side-to-side near top
      if (!e.entered) {
        e.y += e.vy;
        if (e.y > -180) { e.entered = true; }
      } else {
        e.x = Math.sin(frameCount * 0.015) * 300;
        e.y = -180 + Math.sin(frameCount * 0.02) * 30;
      }
      e.shootCooldown--;
      if (e.shootCooldown <= 0 && e.entered) {
        bossShoot(e);
        e.shootCooldown = Math.max(40, 100 - level * 4);
      }
    } else {
      e.vx = Math.sin(e.angle) * 2.5;
      e.x += e.vx; e.y += e.vy;
      if (e.type === 'chaser') {
        e.x += (player.x - e.x) * 0.012;
      }
      if (e.type === 'shooter') {
        e.shootCooldown--;
        if (e.shootCooldown <= 0 && e.y > -200 && e.y < 200) {
          enemyShoot(e);
          AudioEngine.playTone(400, 0.08, 'square', 0.04);
          e.shootCooldown = 120 + Math.random() * 60;
        }
      }
    }
  });

  // Spawn boss every 4 levels
  if (level >= 3 && level % 3 === 0 && level !== bossSpawnedAtLevel && !activeBoss) {
    bossSpawnedAtLevel = level;
    spawnBoss();
  }

  // Spawn regular enemies (slowed during boss)
  const spawnRate = activeBoss
    ? Math.max(80, 140 - level * 3)
    : Math.max(20, 85 - level * 6);
  if (frameCount % spawnRate === 0) spawnEnemy();

  if (frameCount % 540 === 0) spawnPowerup();

  // Update powerups
  powerups = powerups.filter(p => p.y < 400);
  powerups.forEach(p => { p.y += p.vy; });

  // Combo timer
  if (comboTimer > 0) {
    comboTimer--;
    if (comboTimer <= 0) combo = 0;
  }

  // Bullets vs enemies
  for (let bi = bullets.length - 1; bi >= 0; bi--) {
    for (let ei = enemies.length - 1; ei >= 0; ei--) {
      const bullet = bullets[bi];
      const enemy = enemies[ei];
      const dx = bullet.x - enemy.x;
      const dy = bullet.y - enemy.y;
      const dist = Math.sqrt(dx * dx + dy * dy);
      if (dist < enemy.size + 8) {
        enemy.health -= bullet.damage;
        enemy.hitFlash = 8;
        bullets.splice(bi, 1);
        createExplosion(bullet.x, bullet.y, 0, '#ffffff', 4);

        if (enemy.health <= 0) {
          AudioEngine.playExplosion(enemy.isBoss);
          createExplosion(enemy.x, enemy.y, enemy.z, enemy.color, enemy.isBoss ? 60 : 25);
          createShockwave(enemy.x, enemy.y, enemy.z, enemy.color, enemy.isBoss ? 500 : 150);
          if (enemy.isBoss) {
            screenShake = 30;
            activeBoss = null;
            document.getElementById('bossHealth').classList.remove('show');
            // Drop bonus powerups
            for (let k = 0; k < 3; k++) {
              setTimeout(() => spawnPowerup(), k * 200);
            }
          } else {
            screenShake = Math.max(screenShake, 4);
          }

          combo++;
          comboTimer = 120;
          kills++;
          const comboMultiplier = Math.min(combo, 8);
          const points = enemy.score * comboMultiplier;
          score += points;

          if (combo > 1 && combo % 2 === 0) showCombo(combo);

          const p = project(enemy.x, enemy.y, enemy.z);
          createFloatingScore(p.x, p.y, points,
            combo >= 5 ? '#ff00ff' : combo >= 3 ? '#ff8833' : '#00ff88');

          enemies.splice(ei, 1);

          if (score > level * 1500) {
            level++;
            AudioEngine.playLevelUp();
            showLevelUp();
            maxHealth = Math.min(150, 100 + (level - 1) * 5);
            health = Math.min(maxHealth, health + 20);
          }
        }
        break;
      }
    }
  }

  // Player vs enemies
  if (player.invulnerable <= 0) {
    for (let ei = enemies.length - 1; ei >= 0; ei--) {
      const enemy = enemies[ei];
      const dx = player.x - enemy.x;
      const dy = player.y - enemy.y;
      const dist = Math.sqrt(dx * dx + dy * dy);
      if (dist < player.size + enemy.size * 0.8) {
        const dmg = enemy.isBoss ? 35 : 25;
        health -= dmg;
        player.invulnerable = 90;
        AudioEngine.playHit();
        createExplosion(player.x, player.y, 0, '#ff3333', 15);
        showDamage();
        screenShake = 15;
        combo = 0;
        if (!enemy.isBoss) {
          enemy.health = 0;
          createExplosion(enemy.x, enemy.y, enemy.z, enemy.color, 15);
          enemies.splice(ei, 1);
        } else {
          enemy.y -= 60;
        }
        if (health <= 0) { health = 0; gameOver(); return; }
        break;
      }
    }
  }

  // Player vs enemy bullets
  if (player.invulnerable <= 0) {
    for (let bi = enemyBullets.length - 1; bi >= 0; bi--) {
      const b = enemyBullets[bi];
      const dx = player.x - b.x;
      const dy = player.y - b.y;
      if (dx * dx + dy * dy < (player.size + 6) * (player.size + 6)) {
        health -= 15;
        player.invulnerable = 60;
        AudioEngine.playHit();
        createExplosion(player.x, player.y, 0, '#ff3366', 10);
        showDamage();
        screenShake = 10;
        enemyBullets.splice(bi, 1);
        if (health <= 0) { health = 0; gameOver(); return; }
      }
    }
  }

  // Player vs powerups
  for (let pi = powerups.length - 1; pi >= 0; pi--) {
    const p = powerups[pi];
    const dx = player.x - p.x;
    const dy = player.y - p.y;
    const dist = Math.sqrt(dx * dx + dy * dy);
    if (dist < player.size + 25) {
      applyPowerup(p);
      powerups.splice(pi, 1);
    }
  }

  // HUD
  document.getElementById('score').textContent = score.toLocaleString();
  document.getElementById('level').textContent = level;
  document.getElementById('healthFill').style.width = (health / maxHealth * 100) + '%';
  document.getElementById('healthPercent').textContent = Math.ceil(health) + '%';

  if (activeBoss) {
    document.getElementById('bossBarFill').style.width =
      (activeBoss.health / activeBoss.maxHealth * 100) + '%';
  }
}

/* ==================== DRAW ==================== */
function draw() {
  ctx.fillStyle = 'rgba(0, 0, 0, 0.25)';
  ctx.fillRect(0, 0, canvas.width, canvas.height);

  drawStars();
  drawShockwaves();
  drawExplosions();
  powerups.forEach(drawPowerup);
  enemies.forEach(drawEnemy);
  enemyBullets.forEach(drawEnemyBullet);
  bullets.forEach(drawBullet);

  if (gameRunning) drawPlayer();
}

function gameLoop() {
  update();
  draw();
  requestAnimationFrame(gameLoop);
}

/* ==================== GAME STATES ==================== */
function startGame() {
  AudioEngine.init();
  if (ambientSound) {
    try { ambientSound.gain.gain.setValueAtTime(0.02, AudioEngine.ctx.currentTime); } catch(e){}
  } else {
    ambientSound = AudioEngine.playAmbient();
  }

  document.getElementById('startScreen').style.display = 'none';
  document.getElementById('hud').style.display = 'block';
  document.getElementById('crosshair').style.display = 'block';
  document.getElementById('muteBtn').classList.add('visible');
  document.body.style.cursor = 'none';

  score = 0; level = 1; health = 100; maxHealth = 100;
  frameCount = 0; combo = 0; comboTimer = 0; kills = 0;
  bombs = 3;
  document.getElementById('bombCount').textContent = bombs;
  player.x = 0; player.y = 0;
  player.targetX = 0; player.targetY = 0;
  player.invulnerable = 0; player.tilt = 0;

  tripleShotActive = false; shieldActive = false; rapidFireActive = false;
  document.getElementById('tripleShotIndicator').classList.remove('active');
  document.getElementById('shieldIndicator').classList.remove('active');
  document.getElementById('rapidIndicator').classList.remove('active');

  bullets = []; enemies = []; enemyBullets = [];
  powerups = []; explosions = []; shockwaves = [];
  activeBoss = null; bossSpawnedAtLevel = 0;
  document.getElementById('bossHealth').classList.remove('show');

  initStars();
  gameRunning = true;
  gamePaused = false;
}

function gameOver() {
  gameRunning = false;
  AudioEngine.playExplosion(true);
  screenShake = 30;

  const isNewRecord = score > highScore;
  if (isNewRecord) {
    highScore = score;
    localStorage.setItem('galaxyDefenderHighScore', highScore);
  }
  document.getElementById('newRecord').classList.toggle('show', isNewRecord);

  document.getElementById('finalScore').textContent = score.toLocaleString();
  document.getElementById('finalLevel').textContent = level;
  document.getElementById('finalKills').textContent = kills;
  document.getElementById('finalBest').textContent = highScore.toLocaleString();

  setTimeout(() => {
    document.getElementById('gameOverScreen').style.display = 'flex';
    document.getElementById('hud').style.display = 'none';
    document.getElementById('crosshair').style.display = 'none';
    document.body.style.cursor = 'default';
  }, 600);

  if (ambientSound) {
    try {
      ambientSound.gain.gain.exponentialRampToValueAtTime(0.001, AudioEngine.ctx.currentTime + 1);
    } catch (e) {}
  }
}

function restartGame() {
  document.getElementById('gameOverScreen').style.display = 'none';
  document.getElementById('newRecord').classList.remove('show');
  if (ambientSound) {
    try { ambientSound.gain.gain.setValueAtTime(0.02, AudioEngine.ctx.currentTime); } catch(e){}
  }
  startGame();
}

function togglePause() {
  if (!gameRunning) return;
  gamePaused = !gamePaused;
  document.getElementById('pauseOverlay').style.display = gamePaused ? 'flex' : 'none';
}

/* ==================== EVENTS ==================== */
document.getElementById('startBtn').addEventListener('click', startGame);
document.getElementById('restartBtn').addEventListener('click', restartGame);

document.getElementById('muteBtn').addEventListener('click', () => {
  const muted = AudioEngine.toggleMute();
  document.getElementById('muteBtn').textContent = muted ? '🔇' : '🔊';
});

window.addEventListener('keydown', (e) => {
  const k = e.key.toLowerCase();
  keys[k] = true;
  if (k === 'p' || e.key === 'Escape') togglePause();
  if (k === 'b') useBomb();
  if (k === 'm' && AudioEngine.initialized) {
    const muted = AudioEngine.toggleMute();
    document.getElementById('muteBtn').textContent = muted ? '🔇' : '🔊';
  }
  if (k === ' ') e.preventDefault();
});
window.addEventListener('keyup', (e) => { keys[e.key.toLowerCase()] = false; });

window.addEventListener('mousemove', (e) => {
  const crosshair = document.getElementById('crosshair');
  crosshair.style.left = e.clientX + 'px';
  crosshair.style.top = e.clientY + 'px';

  // Mouse also slightly steers ship target
  if (gameRunning && !gamePaused) {
    player.targetX = (e.clientX - canvas.width / 2) * 0.85;
    player.targetY = (e.clientY - canvas.height / 2) * 0.7;
    player.targetX = Math.max(-380, Math.min(380, player.targetX));
    player.targetY = Math.max(-260, Math.min(260, player.targetY));
  }
});
window.addEventListener('mousedown', () => { mouseDown = true; });
window.addEventListener('mouseup', () => { mouseDown = false; });

// Touch support
window.addEventListener('touchmove', (e) => {
  e.preventDefault();
  const t = e.touches[0];
  player.targetX = (t.clientX - canvas.width / 2) * 0.85;
  player.targetY = (t.clientY - canvas.height / 2) * 0.7;
  player.targetX = Math.max(-380, Math.min(380, player.targetX));
  player.targetY = Math.max(-260, Math.min(260, player.targetY));
}, { passive: false });
window.addEventListener('touchstart', (e) => {
  mouseDown = true;
  if (e.touches.length > 1) useBomb();
}, { passive: false });
window.addEventListener('touchend', () => { mouseDown = false; });

// Init
createStartScreenStars();
initStars();
document.getElementById('highScoreDisplay').textContent = highScore.toLocaleString();
gameLoop();
</script>
</body>
