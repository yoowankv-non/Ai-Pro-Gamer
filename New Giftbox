window.addEventListener('DOMContentLoaded', function() {
  var code = "";
  if (window.URLSearchParams) {
    var urlParams = new URLSearchParams(window.location.search);
    code = urlParams.get('gift') || urlParams.get('code');
  }
  if (!code) {
    code = window.location.hash.substring(1);
  }
  if (code) {
    document.getElementById('view-link-input').value = code.trim().toUpperCase();
    goTo('s-view-enter');
    setTimeout(openLoveLink, 300);
  }
});
