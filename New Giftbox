<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>💝 Love Letter Share</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Dancing+Script:wght@400;700&family=Lora:ital,wght@0,400;1,400&display=swap" rel="stylesheet">
<style>
:root {
  --bg:#05010d; --pink:#ff4d8f; --deep-pink:#b8124f; --rose:#e01a78;
  --light-pink:#ffc8e0; --pale-pink:#ffe0ef; --gold:#f5c842; --gold-light:#ffeaa0;
  --glass:rgba(255,60,120,0.07); --glass-b:rgba(255,60,120,0.22);
  --glow:0 0 28px rgba(255,77,143,0.45); --glow-lg:0 0 60px rgba(255,77,143,0.7);
  --font-disp:'Playfair Display',serif; --font-script:'Dancing Script',cursive; --font-body:'Lora',serif;
}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
html,body{width:100%;min-height:100%;overflow-x:hidden;background:var(--bg)}
button{cursor:pointer;border:none;outline:none}
input,textarea,select{outline:none}
::-webkit-scrollbar{width:4px}
::-webkit-scrollbar-thumb{background:var(--deep-pink);border-radius:2px}
#bg-glow{position:fixed;inset:0;pointer-events:none;z-index:0;background:radial-gradient(ellipse 70% 50% at 50% -5%,rgba(200,18,85,0.18) 0%,transparent 70%),radial-gradient(ellipse 50% 40% at 85% 90%,rgba(140,8,55,0.12) 0%,transparent 60%)}
#vignette{position:fixed;inset:0;pointer-events:none;z-index:1;background:radial-gradient(ellipse 100% 100% at 50% 50%,transparent 50%,rgba(0,0,0,0.65) 100%)}
#stars-canvas,#hearts-bg{position:fixed;inset:0;pointer-events:none;z-index:2}
#hearts-bg{z-index:3}
.bg-heart{position:absolute;pointer-events:none;animation:riseHeart linear infinite;opacity:0}
@keyframes riseHeart{0%{transform:translateY(110vh) rotate(0deg) scale(0.6);opacity:0}8%{opacity:0.35}92%{opacity:0.15}100%{transform:translateY(-15vh) rotate(360deg) scale(1.1);opacity:0}}
#music-btn{position:fixed;top:14px;right:14px;z-index:900;width:46px;height:46px;border-radius:50%;background:var(--glass);border:1px solid var(--glass-b);backdrop-filter:blur(12px);color:var(--pink);font-size:20px;display:flex;align-items:center;justify-content:center;box-shadow:var(--glow);transition:all 0.3s}
#music-btn.on{animation:mPulse 1.2s ease-in-out infinite}
@keyframes mPulse{0%,100%{box-shadow:var(--glow)}50%{box-shadow:var(--glow-lg)}}
#app{position:relative;z-index:10;min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:16px}
.screen{display:none;flex-direction:column;align-items:center;width:100%;max-width:460px;min-height:100vh;padding:36px 16px;animation:sIn 0.7s ease forwards}
.screen.active{display:flex;justify-content:center}
@keyframes sIn{from{opacity:0;transform:translateY(18px)}to{opacity:1;transform:translateY(0)}}
.hero-emoji{font-size:72px;margin-bottom:18px;animation:hBeat 1.4s ease-in-out infinite;filter:drop-shadow(0 0 22px rgba(255,77,143,0.85))}
@keyframes hBeat{0%,100%{transform:scale(1)}50%{transform:scale(1.18)}}
.hero-title{font-family:var(--font-script);font-size:clamp(28px,7vw,40px);color:var(--light-pink);text-align:center;margin-bottom:10px;text-shadow:0 0 24px rgba(255,77,143,0.85)}
.hero-sub{font-family:var(--font-body);font-style:italic;font-size:15px;color:rgba(255,205,225,0.65);text-align:center;line-height:1.7;margin-bottom:32px;max-width:320px}
.accordion-toggle{width:100%;text-align:left;background:none;border:none;color:var(--light-pink);font-family:var(--font-script);font-size:18px;padding:8px 0;margin-top:10px;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid rgba(255,77,143,0.25)}
.accordion-content{display:none;padding-top:14px;animation:fadeIn 0.3s ease}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
.btn-primary{padding:13px 30px;border-radius:50px;background:linear-gradient(135deg,var(--rose) 0%,var(--deep-pink) 100%);color:#fff;font-family:var(--font-script);font-size:18px;box-shadow:var(--glow);transition:all 0.3s;margin:5px;letter-spacing:0.4px}
.btn-primary:hover{transform:translateY(-2px);box-shadow:var(--glow-lg)}
.btn-ghost{padding:11px 24px;border-radius:50px;background:transparent;border:1px solid var(--glass-b);color:var(--light-pink);font-family:var(--font-script);font-size:16px;backdrop-filter:blur(8px);transition:all 0.3s;margin:5px}
.btn-ghost:hover{background:var(--glass);border-color:var(--pink);color:var(--pink)}
.btn-row{display:flex;flex-wrap:wrap;justify-content:center;gap:8px;margin-top:12px}
.section-label,.stage-title{font-family:var(--font-script);font-size:clamp(20px,5.5vw,30px);color:var(--light-pink);text-align:center;margin-bottom:22px;text-shadow:0 0 20px rgba(255,77,143,0.85)}
.stage-title{margin-bottom:28px}
.create-card{width:100%;background:rgba(30,2,15,0.92);border:1px solid var(--glass-b);border-radius:18px;padding:28px 22px;backdrop-filter:blur(16px);box-shadow:var(--glow-lg),inset 0 1px 0 rgba(255,255,255,0.05)}
.field-label{font-family:var(--font-script);font-size:16px;color:var(--light-pink);margin-bottom:8px;display:block}
.love-input{width:100%;background:rgba(255,60,120,0.06);border:1px solid var(--glass-b);border-radius:12px;padding:12px 16px;color:rgba(255,220,235,0.92);font-family:var(--font-body);font-style:italic;font-size:15px;resize:none;transition:border-color 0.3s;margin-bottom:20px}
.love-input:focus{border-color:rgba(255,77,143,0.55);box-shadow:0 0 16px rgba(255,77,143,0.2)}
.love-input::placeholder{color:rgba(255,180,210,0.35)}
select.love-input{appearance:none;background-image:radial-gradient(var(--pink) 15%,transparent 16%);background-size:10px 10px}
.photo-upload-area{width:100%;border:1.5px dashed rgba(255,77,143,0.35);border-radius:14px;padding:22px 16px;text-align:center;cursor:pointer;transition:all 0.3s;margin-bottom:20px;background:rgba(255,60,120,0.04)}
.photo-upload-area:hover{border-color:var(--pink);background:rgba(255,60,120,0.09)}
.photo-upload-area .uico{font-size:36px;display:block;margin-bottom:8px}
.photo-upload-area p{font-family:var(--font-script);font-size:16px;color:var(--light-pink)}
.photo-upload-area small{font-size:12px;color:rgba(255,180,210,0.45)}
.photo-thumbs{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:20px}
.thumb{width:68px;height:68px;border-radius:10px;object-fit:cover;border:1.5px solid rgba(255,77,143,0.4);position:relative}
.thumb-wrap{position:relative;display:inline-block}
.thumb-del{position:absolute;top:-6px;right:-6px;width:20px;height:20px;border-radius:50%;background:var(--deep-pink);color:#fff;font-size:11px;display:flex;align-items:center;justify-content:center;cursor:pointer;box-shadow:0 2px 6px rgba(0,0,0,0.4)}
.link-box{width:100%;background:rgba(255,60,120,0.06);border:1px solid rgba(255,77,143,0.3);border-radius:16px;padding:22px;text-align:center;margin-bottom:18px}
.gen-link{font-family:'Courier New',monospace;font-size:28px;color:var(--gold);word-break:break-all;letter-spacing:2px;line-height:1.6;margin:12px 0;cursor:pointer;text-shadow:0 0 10px rgba(245,200,66,0.5);font-weight:bold}
.copy-hint{font-family:var(--font-script);font-size:14px;color:rgba(255,205,225,0.5)}
.link-input-wrap{width:100%;position:relative;margin-bottom:20px}
.link-input-wrap input{width:100%;background:rgba(255,60,120,0.06);border:1px solid var(--glass-b);border-radius:12px;padding:14px 50px 14px 18px;color:rgba(255,220,235,0.92);font-family:'Courier New',monospace;font-size:15px;text-align:center;letter-spacing:1px}
.link-input-wrap input:focus{border-color:rgba(255,77,143,0.55)}
.link-input-wrap input::placeholder{color:rgba(255,180,210,0.3);font-family:var(--font-script);letter-spacing:0px}
.link-submit{position:absolute;right:10px;top:50%;transform:translateY(-50%);width:34px;height:34px;border-radius:50%;background:linear-gradient(135deg,var(--rose),var(--deep-pink));color:#fff;font-size:18px;display:flex;align-items:center;justify-content:center;box-shadow:var(--glow)}
.shake-element{animation:shakeAnim 0.4s ease}
@keyframes shakeAnim{0%,100%{transform:translateX(0)}20%,60%{transform:translateX(-8px)}40%,80%{transform:translateX(8px)}}

#frame-outer {
  width: min(330px, 88vw);
  position: relative;
  margin-bottom: 18px;
  display: flex;
  justify-content: center;
  align-items: center;
  transition: height 0.4s cubic-bezier(0.25, 1, 0.5, 1);
}
#frame-outer::before{content:'';position:absolute;inset:-4px;border-radius:22px;z-index:-1;background:conic-gradient(from 0deg,var(--pink),var(--deep-pink),var(--gold),var(--rose),var(--gold),var(--pink));animation:spin 3.5s linear infinite}
#frame-outer::after{content:'';position:absolute;inset:-3px;border-radius:21px;z-index:-2;background:conic-gradient(from 0deg,var(--pink),var(--deep-pink),var(--gold),var(--rose),var(--gold),var(--pink));animation:spin 3.5s linear infinite;filter:blur(9px)}
@keyframes spin{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}

#photo-frame {
  width: 100%;
  height: auto;
  min-height: 150px;
  border-radius: 18px;
  background: rgba(18, 2, 12, 0.92);
  border: 2px solid rgba(255, 60, 120, 0.28);
  overflow: hidden;
  position: relative;
  backdrop-filter: blur(12px);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: height 0.4s cubic-bezier(0.25, 1, 0.5, 1);
}

#cur-photo {
  display: block;
  max-width: 100%;
  max-height: min(390px, 58vh);
  width: auto;
  height: auto;
  object-fit: contain;
  border-radius: 16px;
  transition: opacity 0.4s ease;
}
#cur-photo.fade-out{opacity:0;transform:scale(0.96)}
#cur-photo.fade-in{animation:pIn 0.4s cubic-bezier(0.25, 1, 0.5, 1) forwards}
@keyframes pIn{from{opacity:0;transform:scale(0.96)}to{opacity:1;transform:scale(1)}}

.photo-bottom{position:absolute;bottom:0;left:0;right:0;background:linear-gradient(transparent,rgba(0,0,0,0.62));padding:22px 12px 10px;font-family:var(--font-script);font-size:13px;color:rgba(255,205,225,0.85);text-align:center}
.no-photo-ph{display:flex;flex-direction:column;align-items:center;gap:8px;opacity:0.5;padding:20px;text-align:center}
.no-photo-ph span{font-size:44px}
.no-photo-ph p{font-family:var(--font-script);font-size:16px;color:var(--light-pink)}
#slide-ctrl{display:flex;align-items:center;gap:18px;margin-bottom:14px}
#slide-ctrl button{width:38px;height:38px;border-radius:50%;background:var(--glass);border:1px solid var(--glass-b);color:var(--pink);font-size:24px;display:flex;align-items:center;justify-content:center;backdrop-filter:blur(8px);transition:all 0.3s}
#slide-ctrl button:hover{background:rgba(255,60,120,0.2);transform:scale(1.12);box-shadow:var(--glow)}
#photo-count{font-family:var(--font-script);font-size:16px;color:var(--light-pink);min-width:52px;text-align:center}
#letter-wrap{width:min(370px,92vw);position:relative}
#env-icon{text-align:center;font-size:68px;margin-bottom:18px;animation:envRock 2.2s ease-in-out infinite;filter:drop-shadow(0 0 22px rgba(255,77,143,0.85))}
@keyframes envRock{0%,100%{transform:scale(1) rotate(-3deg)}50%{transform:scale(1.1) rotate(3deg)}}
#letter-paper{background:linear-gradient(145deg,rgba(38,3,18,0.97) 0%,rgba(26,1,12,0.99) 100%);border:1px solid rgba(255,60,120,0.32);border-radius:14px;backdrop-filter:blur(22px);box-shadow:var(--glow-lg),inset 0 1px 0 rgba(255,255,255,0.05),0 22px 65px rgba(0,0,0,0.55);transform-origin:top center;animation:unfold 1s cubic-bezier(0.4,0,0.2,1) forwards;position:relative;overflow:hidden}
#letter-paper::before{content:'';position:absolute;inset:0;pointer-events:none;opacity:0.03;background:repeating-linear-gradient(-45deg,var(--pink) 0px,var(--pink) 1px,transparent 1px,transparent 18px)}
@keyframes unfold{0%{transform:scaleY(0.04) perspective(500px) rotateX(-40deg);opacity:0}40%{transform:scaleY(0.5) perspective(500px) rotateX(-10deg);opacity:0.8}100%{transform:scaleY(1) perspective(500px) rotateX(0deg);opacity:1}}
#letter-content{padding:32px 28px;position:relative;z-index:1}
.letter-deco{text-align:center;font-size:22px;letter-spacing:10px;margin-bottom:14px}
.letter-line{width:100%;height:1px;margin:16px 0;background:linear-gradient(to right,transparent,rgba(255,60,120,0.4),transparent)}
.letter-head{font-family:var(--font-script);font-size:clamp(22px,5.5vw,28px);color:var(--light-pink);margin-bottom:18px;text-shadow:0 0 16px rgba(255,77,143,0.65)}
#letter-body{font-family:var(--font-body);font-style:italic;font-size:clamp(15px,3.8vw,18px);line-height:1.95;color:rgba(255,205,225,0.92);min-height:100px;white-space:pre-line}
#letter-body .cur{display:inline-block;width:2px;height:1.1em;background:var(--pink);margin-left:2px;vertical-align:text-bottom;animation:blink 0.7s step-end infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:0}}
.letter-sig{font-family:var(--font-script);font-size:clamp(18px,4.5vw,22px);color:var(--pink);text-align:right;margin-top:22px;text-shadow:0 0 16px rgba(255,77,143,0.65);opacity:0;transition:opacity 1s}
.letter-sig.show{opacity:1}
.sparkle{position:fixed;pointer-events:none;animation:sparkAnim 0.9s ease forwards;z-index:300}
@keyframes sparkleAnim{0%{transform:scale(0) rotate(0deg);opacity:1}50%{transform:scale(1.6) rotate(180deg);opacity:1}100%{transform:scale(0) rotate(360deg);opacity:0}}
#popup{position:fixed;inset:0;z-index:800;background:rgba(0,0,0,0.88);backdrop-filter:blur(12px);display:flex;align-items:center;justify-content:center;padding:20px;opacity:0;pointer-events:none;transition:opacity 0.55s}
#popup.show{opacity:1;pointer-events:all}
.popup-box{background:linear-gradient(145deg,rgba(45,4,22,0.98) 0%,rgba(28,1,12,0.99) 100%);border:1px solid rgba(255,60,120,0.42);border-radius:22px;padding:44px 30px;text-align:center;max-width:360px;width:100%;box-shadow:0 0 90px rgba(255,77,143,0.45),inset 0 1px 0 rgba(255,255,255,0.05);animation:popIn 0.65s cubic-bezier(0.34,1.56,0.64,1) forwards}
@keyframes popIn{from{transform:scale(0.45) translateY(28px);opacity:0}to{transform:scale(1) translateY(0);opacity:1}}
.popup-emoji{font-size:66px;display:block;margin-bottom:18px;animation:hBeat2 1.1s ease-in-out infinite}
@keyframes hBeat2{0%,100%{transform:scale(1)}50%{transform:scale(1.22)}}
.popup-title{font-family:var(--font-script);font-size:34px;color:var(--light-pink);text-shadow:0 0 22px rgba(255,77,143,0.85);margin-bottom:12px}
.popup-sub{font-family:var(--font-body);font-style:italic;font-size:16px;color:rgba(255,205,225,0.82);line-height:1.65;margin-bottom:28px}
#particles-canvas{position:fixed;inset:0;pointer-events:none;z-index:200;display:none}
.status-msg{font-family:var(--font-script);font-size:15px;text-align:center;margin-top:12px;min-height:22px;transition:opacity 0.4s}
.status-msg.err{color:#ff6b6b}
.status-msg.ok{color:#7effb2}

@media print {
  body * { visibility: hidden !important; background: none !important; }
  #app, #s-letter, #letter-wrap, #letter-paper, #letter-content, #letter-content * {
    visibility: visible !important;
  }
  body, #app, #s-letter, #letter-wrap {
    background: #fff !important;
    color: #260312 !important;
    position: static !important;
    width: 100% !important;
    height: auto !important;
    box-shadow: none !important;
  }
  #letter-paper {
    border: 2px solid #ff4d8f !important;
    background: #fff8fb !important;
    box-shadow: none !important;
    transform: none !important;
    width: 100% !important;
    margin: 0 auto !important;
  }
  #letter-body .cur, #music-btn, .btn-row, #env-icon {
    display: none !important;
  }
}
</style>
</head>
<body>
<div id="bg-glow"></div>
<div id="vignette"></div>
<canvas id="stars-canvas"></canvas>
<div id="hearts-bg"></div>
<button id="music-btn" onclick="toggleMusic()" title="Music">🎵</button>
<canvas id="particles-canvas"></canvas>

<div id="app">

  <!-- ===== HOME SCREEN ===== -->
  <div id="s-home" class="screen active">
    <div class="hero-emoji">💝</div>
    <div class="hero-title">Love Letter Share</div>
    <div class="hero-sub">Apne pyaar ko ek special gift bhejo — photos, letter, aur custom preferences ke sath ek secret code mein</div>
    <div class="btn-row">
      <button class="btn-primary" onclick="goTo('s-create')">💌 Create Secret Code</button>
      <button class="btn-ghost" onclick="goTo('s-view-enter')">🔑 Enter Secret Code</button>
    </div>
    <div class="btn-row">
      <button class="btn-ghost" onclick="goTo('s-track-enter')" style="font-size:14px; opacity:0.85">🕵️ Track Sent Gift</button>
    </div>
  </div>

  <!-- ===== CREATE SCREEN ===== -->
  <div id="s-create" class="screen">
    <div class="stage-title">✨ Create Your Love Gift ✨</div>
    <div class="create-card">

      <label class="field-label">💕 Receiver ka naam</label>
      <input class="love-input" id="c-receiver" type="text" placeholder="e.g. Meri Jaan, My Love..." style="height:46px">

      <label class="field-label">💌 Apna Love Letter likho</label>
      <textarea class="love-input" id="c-letter" rows="5" placeholder="Yahan se apna dil kholo... jo bhi feel karo woh likho ❤️"></textarea>

      <label class="field-label">📷 Photos add karo (optional)</label>
      <div class="photo-upload-area" onclick="document.getElementById('c-photo-input').click()">
        <span class="uico">📸</span>
        <p>Tap karo photos add karne ke liye</p>
        <small>Multiple photos choose kar sakte ho</small>
      </div>
      <input type="file" id="c-photo-input" multiple accept="image/*" onchange="handleCreatePhotos(event)" style="display:none">
      <div id="c-thumbs" class="photo-thumbs" style="display:none"></div>

      <label class="field-label">✍️ Sender naam (signature)</label>
      <input class="love-input" id="c-sender" type="text" placeholder="Tumhara naam ya nickname..." style="height:46px">

      <!-- COLLAPSIBLE EXTRA PREFERENCES -->
      <button type="button" class="accordion-toggle" onclick="toggleAccordion('custom-options-panel')">
        ⚙️ Extra Customizations <span id="acc-icon">＋</span>
      </button>
      
      <div id="custom-options-panel" class="accordion-content">
        <label class="field-label">🎵 Custom Background Track</label>
        <select class="love-input" id="c-track" style="height:46px">
          <option value="classic">Romantic Synthesizer (Default)</option>
          <option value="lullaby">Dreamy Lullaby (Soft Piano)</option>
          <option value="waltz">Starry Waltz (Slow & Majestic)</option>
        </select>

        <label class="field-label">🔒 Set Password (Optional)</label>
        <input class="love-input" id="c-password" type="password" placeholder="Passcode rakho (receiver ke liye)" style="height:46px">

        <label class="field-label">📅 Expiry Date (Optional)</label>
        <input class="love-input" id="c-expiry" type="date" style="height:46px">
      </div>

    </div>
    <div class="btn-row" style="margin-top:18px">
      <button class="btn-primary" onclick="generateLink()">✨ Generate Love Code</button>
      <button class="btn-ghost" onclick="goTo('s-home')">← Wapas</button>
    </div>
    <div id="create-status" class="status-msg"></div>
  </div>

  <!-- ===== LINK GENERATED SCREEN ===== -->
  <div id="s-link-done" class="screen">
    <div class="hero-emoji" style="font-size:56px">🎉</div>
    <div class="stage-title">Code Tayyar Hai! 💕</div>

    <div class="link-box">
      <p style="font-family:var(--font-script);font-size:15px;color:var(--light-pink);margin-bottom:8px">Yeh unique Code apne partner ke sath share karein:</p>
      <div class="gen-link" id="gen-link-text" onclick="copyUniqueCode()">—</div>
      <p class="copy-hint">↑ Tap karo code copy karne ke liye</p>
    </div>
    <div class="btn-row">
      <button class="btn-primary" onclick="copyUniqueCode()">📋 Copy Unique Code</button>
    </div>
    <p style="font-family:var(--font-script);font-size:14px;color:rgba(255,205,225,0.5);text-align:center;margin:14px 0;line-height:1.8">
      Jab woh yeh code "Enter Secret Code" section mein paste karenge,<br>unhe aapka bheja hua poora gift dikhega 💝
    </p>
    <div id="copy-status" class="status-msg"></div>
    <div class="btn-row">
      <button class="btn-ghost" onclick="goTo('s-home')">🏠 Home</button>
    </div>
  </div>

  <!-- ===== VIEW ENTER LINK SCREEN ===== -->
  <div id="s-view-enter" class="screen">
    <div class="hero-emoji" style="font-size:56px">🔑</div>
    <div class="stage-title">Secret Code Enter Karo 💌</div>
    <p style="font-family:var(--font-script);font-size:16px;color:rgba(255,205,225,0.6);text-align:center;margin-bottom:28px;line-height:1.8">
      Tumhe jo unique code mila hai woh<br>yahan enter karo
    </p>
    <div style="width:100%;max-width:380px">
