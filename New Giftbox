// ==========================================
// COMPATIBLE NETWORK TIMEOUT UTILITY
// ==========================================
function promiseWithTimeout(promise, ms) {
  return new Promise(function(resolve, reject) {
    var id = setTimeout(function() {
      clearTimeout(id);
      reject(new Error('NetworkTimeout'));
    }, ms);
    promise.then(function(res) {
      clearTimeout(id);
      resolve(res);
    }).catch(function(err) {
      clearTimeout(id);
      reject(err);
    });
  });
}

// ==========================================
// COMPATIBLE STABLE STORAGE LAYER (OFFLINE-FIRST + CRASH PROOF)
// ==========================================
function saveGift(code, data) {
  return new Promise(function(resolve) {
    var serializedData = "";
    try {
      serializedData = JSON.stringify(data);
      localStorage.setItem('gift:' + code, serializedData);
    } catch(e) {
      console.warn("Storage Full! Pruning heavy media elements to prevent a crash...", e);
      // Fallback: Strip heavy images to guarantee successful letter generation
      try {
        var fallbackData = {
          receiver: data.receiver,
          letter: data.letter,
          sender: data.sender,
          photos: [], // Strip photos
          musicTrack: data.musicTrack,
          passwordHash: data.passwordHash,
          expiry: data.expiry,
          createdAt: data.createdAt,
          openedAt: data.openedAt,
          warning: "photos_stripped"
        };
        serializedData = JSON.stringify(fallbackData);
        localStorage.setItem('gift:' + code, serializedData);
        alert("⚠️ Photos size bahut badi hai! Aapka Letter safely save ho gaya hai, par space bachane ke liye images ko skip kar diya gaya hai.");
      } catch(innerErr) {
        console.error("Critical storage write failed:", innerErr);
      }
    }

    if (window.storage && typeof window.storage.set === 'function') {
      promiseWithTimeout(window.storage.set('gift:' + code, serializedData, true), 1500)
        .then(function() {
          resolve(true);
        })
        .catch(function(err) {
          console.warn("Network storage failed/timed out, local offline save is stable:", err);
          resolve(true); // Always return true to let user continue
        });
    } else {
      resolve(true);
    }
  });
}

function loadGift(code) {
  return new Promise(function(resolve) {
    try {
      var localRaw = localStorage.getItem('gift:' + code);
      if (localRaw) {
        resolve(JSON.parse(localRaw));
        return;
      }
    } catch(e) {
      console.warn("Local storage fetch failed:", e);
    }

    if (window.storage && typeof window.storage.get === 'function') {
      promiseWithTimeout(window.storage.get('gift:' + code, true), 3000)
        .then(function(r) {
          if (r && r.value) {
            try {
              var parsed = JSON.parse(r.value);
              try {
                localStorage.setItem('gift:' + code, r.value);
              } catch(se) {}
              resolve(parsed);
            } catch(e) {
              resolve(null);
            }
          } else {
            resolve(null);
          }
        })
        .catch(function(err) {
          console.warn("Remote storage fetch failed or timed out:", err);
          resolve(null);
        });
    } else {
      resolve(null);
    }
  });
}

// ==========================================
// FAILSAFE UNIVERSAL CLIPBOARD COPY UTILITY
// ==========================================
function copyToClipboard(text) {
  return new Promise(function(resolve, reject) {
    try {
      var textArea = document.createElement("textarea");
      textArea.value = text;
      textArea.style.position = "absolute";
      textArea.style.left = "-9999px";
      document.body.appendChild(textArea);
      textArea.select();
      var successful = document.execCommand('copy');
      document.body.removeChild(textArea);
      if (successful) {
        resolve();
        return;
      }
    } catch (e) {
      console.warn("Failsafe traditional copy failed:", e);
    }

    if (navigator.clipboard && typeof navigator.clipboard.writeText === 'function') {
      navigator.clipboard.writeText(text).then(resolve).catch(reject);
    } else {
      reject(new Error('FailsafeCopyBlocked'));
    }
  });
}

