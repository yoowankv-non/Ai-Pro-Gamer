  c.style.display = createPhotos.length ? 'flex' : 'none';
  c.innerHTML = '';
  createPhotos.forEach(function(src, i) {
    var wrap = document.createElement('div');
    wrap.className = 'thumb-wrap';
    var img = document.createElement('img');
    img.className = 'thumb';
    img.src = src;
    var del = document.createElement('div');
    del.className = 'thumb-del';
    del.textContent = '×';
    del.onclick = function() {
      createPhotos.splice(i, 1);
      renderThumbs();
    };
    wrap.appendChild(img);
    wrap.appendChild(del);
    c.appendChild(wrap);
  });
}

// ===========================
// GENERATE NEW LOVE GIFT
// ===========================
function generateLink() {
  var receiver = document.getElementById('c-receiver').value.trim();
  var letter = document.getElementById('c-letter').value.trim();
  var sender = document.getElementById('c-sender').value.trim();
  var musicTrack = document.getElementById('c-track').value;
  var password = document.getElementById('c-password').value.trim();
  var expiry = document.getElementById('c-expiry').value;
  var statusEl = document.getElementById('create-status');

  if (!letter) {
    statusEl.textContent = '💔 Letter likhna zaruri hai!';
    statusEl.className = 'status-msg err';
    return;
  }

  statusEl.textContent = '⏳ Code banaya ja raha hai...';
  statusEl.className = 'status-msg ok';

  var code = Math.random().toString(36).substring(2, 8).toUpperCase();

  hashStr(password).then(function(passwordHash) {
    var data = {
      receiver: receiver || 'Meri Jaan',
      letter: letter,
      sender: sender || 'Tumhara Hamesha',
      photos: createPhotos,
      musicTrack: musicTrack,
      passwordHash: passwordHash,
      expiry: expiry,
      createdAt: Date.now(),
      openedAt: null
    };

    saveGift(code, data).then(function(ok) {
      if (!ok) {
        statusEl.textContent = '❌ Code save nahi hua, dobara try karein';
        statusEl.className = 'status-msg err';
        return;
      }

      playGenerateSuccessSound();

      document.getElementById('gen-link-text').textContent = code;
      goTo('s-link-done');

      // Reset states
      document.getElementById('create-status').textContent = '';
      createPhotos = [];
      document.getElementById('c-thumbs').innerHTML = '';
      document.getElementById('c-thumbs').style.display = 'none';
      document.getElementById('c-receiver').value = '';
      document.getElementById('c-letter').value = '';
      document.getElementById('c-sender').value = '';
      document.getElementById('c-password').value = '';
      document.getElementById('c-expiry').value = '';
    });
  });
}

function copyUniqueCode() {
  var code = document.getElementById('gen-link-text').textContent;
  copyToClipboard(code).then(function() {
    var s = document.getElementById('copy-status');
    s.textContent = '✅ Code clipboard me copy ho gaya!';
    s.className = 'status-msg ok';
    setTimeout(function() { s.textContent = ''; }, 3500);
  }).catch(function() {
    var s = document.getElementById('copy-status');
    s.textContent = '⚠️ Code clipboard block hai! Manually copy: ' + code;
    s.className = 'status-msg err';
  });
}

// ===========================
// PROCESS/VERIFY LOVE LINK
// ===========================
var giftData = null;
var currentCode = null;

function openLoveLink() {
  var codeInput = document.getElementById('view-link-input').value.trim().toUpperCase();
  var statusEl = document.getElementById('view-status');

  if (!codeInput) {
    statusEl.textContent = '💔 Please enter code!';
    statusEl.className = 'status-msg err';
    return;
  }

  statusEl.textContent = '⏳ Loading secret space...';
  statusEl.className = 'status-msg ok';

  loadGift(codeInput).then(function(data) {
    if (!data) {
      statusEl.textContent = '❌ Yeh code galat hai ya slow internet ki wajah se load nahi ho saka.';
      statusEl.className = 'status-msg err';
      return;
    }

    if (data.expiry) {
      var today = new Date().setHours(0,0,0,0);
      var expiryDate = new Date(data.expiry).setHours(0,0,0,0);
      if (today > expiryDate) {
        statusEl.textContent = '🥀 Yeh code expire ho chuka hai...';
        statusEl.className = 'status-msg err';
        return;
      }
    }

    giftData = data;
    currentCode = codeInput;
    statusEl.textContent = '';

    if (giftData.passwordHash) {
      goTo('s-password-prompt');
    } else {
      initiateGiftView();
    }
  });
}

function verifyPasswordGift() {
  var pw = document.getElementById('decrypt-password-input').value;
  var statusEl = document.getElementById('password-status');
  
  hashStr(pw).then(function(userHash) {
    if (userHash === giftData.passwordHash) {
      statusEl.textContent = '';
      initiateGiftView();
    } else {
      statusEl.textContent = '❌ Galat password! Yaad karne ki koshish karein.';
      statusEl.className = 'status-msg err';
    }
  });
}

function initiateGiftView() {
  if (!giftData.openedAt) {
    giftData.openedAt = Date.now();
    saveGift(currentCode, giftData).then(function() {
      document.getElementById('gift-greeting').textContent = '✨ ' + giftData.receiver + ' ke Liye ✨';
      goTo('s-gift');
      initGiftGame();
    });
  } else {
    document.getElementById('gift-greeting').textContent = '✨ ' + giftData.receiver + ' ke Liye ✨';
    goTo('s-gift');
    initGiftGame();
  }
}

