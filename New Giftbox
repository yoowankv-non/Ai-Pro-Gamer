let audioCtx=null,masterGain=null,musicOn=false,melodyLoopTimeout=null;

const MELODIES = {
  classic: [
    [329.63,1],[261.63,.5],[293.66,.5],[392,.1],[349.23,.75],[329.63,.75],[293.66,.5],[261.63,2],
    [293.66,1],[329.63,.5],[349.23,.5],[392,1],[440,.75],[392,.75],[349.23,.5],[329.63,2]
  ],
  lullaby: [
    [261.63,1.5],[329.63,1.5],[392.00,3],[349.23,1.5],[293.66,1.5],[261.63,3],
    [440.00,1.5],[349.23,1.5],[392.00,3],[329.63,1.5],[261.63,1.5],[293.66,3]
  ],
  waltz: [
    [392.00,2],[440.00,1],[493.88,2],[523.25,1],[587.33,3],[523.25,2],[493.88,1],
    [440.00,2],[392.00,1],[349.23,2],[392.00,1],[293.66,3]
  ]
};

function scheduleMelody() {
  if (!musicOn || !masterGain) return;
  const currentTrack = (giftData && giftData.musicTrack) ? giftData.musicTrack : 'classic';
  const notes = MELODIES[currentTrack] || MELODIES.classic;
  const bpm = currentTrack === 'waltz' ? 84 : 68;
  const beat = 60 / bpm;
  let t = audioCtx.currentTime + 0.08;

  for (var i = 0; i < notes.length; i++) {
    var freq = notes[i][0];
    var beats = notes[i][1];
    const dur = beats * beat;
    const osc = audioCtx.createOscillator(), eg = audioCtx.createGain();
    osc.type = (currentTrack === 'lullaby') ? 'triangle' : 'sine';
    osc.frequency.setValueAtTime(freq, t);
    eg.gain.setValueAtTime(0, t);
    eg.gain.linearRampToValueAtTime(0.065, t + 0.04);
    eg.gain.exponentialRampToValueAtTime(0.001, t + dur - 0.04);
    osc.connect(eg);
    eg.connect(masterGain);
    osc.start(t);
    osc.stop(t + dur);
    t += dur;
  }

  const baseChords = currentTrack === 'lullaby' ? [130.81, 164.81, 196.00] : [130.81, 155.56, 196.00];
  for (var k = 0; k < baseChords.length; k++) {
    var f = baseChords[k];
    const osc = audioCtx.createOscillator(), eg = audioCtx.createGain();
    osc.type = 'triangle';
    osc.frequency.setValueAtTime(f, audioCtx.currentTime);
    eg.gain.setValueAtTime(0, audioCtx.currentTime);
    eg.gain.linearRampToValueAtTime(0.02, audioCtx.currentTime + 1);
    eg.gain.linearRampToValueAtTime(0.02, audioCtx.currentTime + 5);
    eg.gain.linearRampToValueAtTime(0, audioCtx.currentTime + 7);
    osc.connect(eg);
    eg.connect(masterGain);
    osc.start(audioCtx.currentTime);
    osc.stop(audioCtx.currentTime + 7);
  }

  const totalTime = notes.reduce(function(sum, item) { return sum + item[1]; }, 0) * beat * 1000;
  melodyLoopTimeout = setTimeout(function() {
    if (musicOn) scheduleMelody();
  }, totalTime - 80);
}

function toggleMusic() {
  const btn = document.getElementById('music-btn');
  if (!musicOn) {
    audioCtx = audioCtx || new (window.AudioContext || window.webkitAudioContext)();
    if (audioCtx.state === 'suspended') audioCtx.resume();
    masterGain = audioCtx.createGain();
    masterGain.gain.setValueAtTime(0.45, audioCtx.currentTime);
    masterGain.connect(audioCtx.destination);
    musicOn = true;
    scheduleMelody();
    btn.textContent = '🔇';
    btn.classList.add('on');
  } else {
    musicOn = false;
    clearTimeout(melodyLoopTimeout);
    if (masterGain) masterGain.gain.linearRampToValueAtTime(0, audioCtx.currentTime + 0.4);
    btn.textContent = '🎵';
    btn.classList.remove('on');
  }
}

