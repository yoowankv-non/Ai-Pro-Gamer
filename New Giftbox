// ==========================================
// BACKWARD-COMPATIBLE PROMISE HASH (SHA-256 FALLBACK)
// ==========================================
function hashStr(text) {
  return new Promise(function(resolve) {
    if (!text) {
      resolve("");
      return;
    }
    
    var hasCrypto = typeof window !== 'undefined' && window.crypto && window.crypto.subtle;
    if (!hasCrypto) {
      var hash = 5381;
      for (var i = 0; i < text.length; i++) {
        hash = ((hash << 5) + hash) + text.charCodeAt(i);
      }
      resolve("offline-fallback:" + (hash >>> 0).toString(16));
      return;
    }

    try {
      var msgUint8 = new TextEncoder().encode(text);
      window.crypto.subtle.digest('SHA-256', msgUint8)
        .then(function(hashBuffer) {
          var hashArray = Array.from(new Uint8Array(hashBuffer));
          var hex = hashArray.map(function(b) {
            var s = b.toString(16);
            return s.length < 2 ? '0' + s : s;
          }).join('');
          resolve(hex);
        })
        .catch(function() {
          resolve("safe-fallback:" + btoa(text).substring(0, 10));
        });
    } catch (e) {
      resolve("safe-fallback:" + btoa(text).substring(0, 10));
    }
  });
}

