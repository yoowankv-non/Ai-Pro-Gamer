function trackGift() {
  var trackingCode = document.getElementById('track-code-input').value.trim().toUpperCase();
  var statusEl = document.getElementById('track-status');

  if (!trackingCode) {
    statusEl.textContent = '🔍 Please enter a code!';
    statusEl.className = 'status-msg err';
    return;
  }

  statusEl.textContent = '⏳ State check kiya ja raha hai...';
  statusEl.className = 'status-msg ok';

  loadGift(trackingCode).then(function(data) {
    if (!data) {
      statusEl.textContent = '❌ Code sahi nahi mila!';
      statusEl.className = 'status-msg err';
      return;
    }

    if (data.openedAt) {
      var openDate = new Date(data.openedAt).toLocaleString();
      statusEl.innerHTML = '💖 <strong>Opened!</strong><br>Aapka gift <strong>' + openDate + '</strong> ko open kiya gaya hai! ✨';
      statusEl.className = 'status-msg ok';
    } else {
      statusEl.innerHTML = '✉️ <strong>Not Opened yet!</strong><br>Receiver ne abhi tak gift open nahi kiya hai.';
      statusEl.className = 'status-msg ok';
    }
  });
}

// =======================================
// MINI-GAME ENGINE (NEON BUBBLE POPPING)
// =======================================
var gameActive = false;
var gameScore = 0;
var gameItems = [];
var gameParticles = [];
var gameRings = []; 
var gameAnimationFrameId = null;

function initGiftGame() {
  var canvas = document.getElementById('game-canvas');
  var ctx = canvas.getContext('2d');
  
  canvas.width = canvas.offsetWidth || 340;
  canvas.height = canvas.offsetHeight || 390;
  
  gameActive = true;
  gameScore = 0;
  gameItems = [];
  gameParticles = [];
  gameRings = [];
  
  document.getElementById('game-score-display').textContent = 'Collected: 0 / 10';
  document.getElementById('game-finish-row').style.display = 'none';
  document.getElementById('game-instructions').style.opacity = '1';

  function handleCanvasTap(clientX, clientY) {
    if (!gameActive) return;
    var rect = canvas.getBoundingClientRect();
    var tapX = clientX - rect.left;
    var tapY = clientY - rect.top;

    document.getElementById('game-instructions').style.opacity = '0';

    for (var i = gameItems.length - 1; i >= 0; i--) {
      var it = gameItems[i];
      var hitboxRadius = 36;
      
      // Fallback distance calculation if Math.hypot is missing
      var distance = Math.hypot ? Math.hypot(tapX - it.x, tapY - it.y) : Math.sqrt(Math.pow(tapX - it.x, 2) + Math.pow(tapY - it.y, 2));

      if (distance < hitboxRadius) {
        gameRings.push({
          x: it.x,
          y: it.y,
          r: 10,
          maxR: 52,
          color: it.isObstacle ? '#ff3b30' : '#ff4d8f',
          lineWidth: 5,
          alpha: 1
        });

        if (it.isObstacle) {
          gameScore = Math.max(0, gameScore - 1);
          playOopsSound();
          var box = document.getElementById('game-wrapper-box');
          box.classList.add('shake-element');
          setTimeout(function() { box.classList.remove('shake-element'); }, 400);

          for (var j = 0; j < 8; j++) {
            gameParticles.push({
              x: it.x, y: it.y,
              vx: (Math.random() - 0.5) * 5, vy: (Math.random() - 0.5) * 5,
              alpha: 1, size: Math.random() * 4 + 4, color: '#ff3b30'
            });
          }
        } else {
          gameScore++;
          playCollectSound();

          for (var j = 0; j < 15; j++) {
            gameParticles.push({
              x: it.x, y: it.y,
              vx: (Math.random() - 0.5) * 7, vy: (Math.random() - 0.5) * 7 - 1.5,
              alpha: 1, size: Math.random() * 5 + 3, color: Math.random() < 0.5 ? 'var(--pink)' : 'var(--gold)'
            });
          }
        }

        document.getElementById('game-score-display').textContent = 'Collected: ' + gameScore + ' / 10';
        gameItems.splice(i, 1);

        if (gameScore >= 10) {
          triggerGameVictory();
        }
        break; 
      }
    }
  }

  canvas.onmousedown = function(e) {
    handleCanvasTap(e.clientX, e.clientY);
  };

  canvas.ontouchstart = function(e) {
    if (e.touches.length > 0) {
      e.preventDefault(); 
      handleCanvasTap(e.touches[0].clientX, e.touches[0].clientY);
    }
  };

  var frameCount = 0;

  function gameLoop() {
    if (!gameActive) return;
    
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    frameCount++;

    if (frameCount % 45 === 0) {
      var isObstacle = Math.random() < 0.15;
      var spawnX = Math.random() * (canvas.width - 70) + 35;
      gameItems.push({
        startX: spawnX, 
        x: spawnX,
        y: -40,
        swaySpeed: Math.random() * 0.025 + 0.015,
        swayAmplitude: Math.random() * 16 + 6,
        swayPhase: Math.random() * Math.PI * 2,
        vy: Math.random() * 1.3 + 1.6, 
        emoji: isObstacle ? '💔' : ['💌', '💖', '🎁', '🌸', '✨'][Math.floor(Math.random() * 5)],
        size: Math.random() * 5 + 24,
        scale: 0.1, 
        targetScale: 1.0,
        angle: Math.random() * Math.PI * 2,
        rotationSpeed: (Math.random() - 0.5) * 0.03, 
        isObstacle: isObstacle
      });
    }

    for (var i = gameItems.length - 1; i >= 0; i--) {
      var it = gameItems[i];
      
      it.y += it.vy;
      it.x = it.startX + Math.sin(it.swayPhase + frameCount * it.swaySpeed) * it.swayAmplitude;
      it.angle += it.rotationSpeed;
      
      if (it.scale < it.targetScale) {
        it.scale += (it.targetScale - it.scale) * 0.08; // Ultra smooth elastic ease-in
      }

      ctx.save();
      ctx.translate(it.x, it.y);
      ctx.rotate(it.angle);
      ctx.scale(it.scale, it.scale);

      const bubbleRadius = 24;
      const grad = ctx.createRadialGradient(0, 0, 0, 0, 0, bubbleRadius);
      if (it.isObstacle) {
        grad.addColorStop(0, 'rgba(255, 235, 235, 0.98)');
        grad.addColorStop(0.65, 'rgba(255, 60, 60, 0.9)');
        grad.addColorStop(1, '#ff3b30');
      } else {
        grad.addColorStop(0, 'rgba(255, 245, 250, 0.98)');
        grad.addColorStop(0.65, 'rgba(255, 110, 175, 0.9)');
        grad.addColorStop(1, '#ff4d8f');
      }

      ctx.shadowBlur = 18;
      ctx.shadowColor = it.isObstacle ? '#ff3b30' : '#ff4d8f';
      
      ctx.beginPath();
      ctx.arc(0, 0, bubbleRadius, 0, Math.PI * 2);
      ctx.fillStyle = grad;
      ctx.fill();
      
      ctx.lineWidth = 2.2;
      ctx.strokeStyle = it.isObstacle ? '#ff735c' : '#ffffff';
      ctx.stroke();

      ctx.shadowBlur = 12;
      ctx.shadowColor = it.isObstacle ? 'rgba(255, 59, 48, 0.7)' : 'rgba(255, 77, 143, 0.7)';

      ctx.beginPath();
      // Ellipse fallback check for older webview engines
      if (typeof ctx.ellipse === 'function') {
        ctx.ellipse(-8, -8, 6, 3, -Math.PI / 4, 0, Math.PI * 2);
      } else {
        ctx.arc(-8, -8, 5, 0, Math.PI * 2);
      }
      ctx.fillStyle = 'rgba(255, 255, 255, 0.55)';
      ctx.fill();

      ctx.font = 'bold ' + it.size + 'px serif';
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      ctx.fillText(it.emoji, 0, 0);

      ctx.restore();

      if (it.y > canvas.height + 40) {
        gameItems.splice(i, 1);
      }
    }

    for (var i = gameRings.length - 1; i >= 0; i--) {
      var ring = gameRings[i];
      ring.r += (ring.maxR - ring.r) * 0.15; 
      ring.lineWidth -= 0.18;
      ring.alpha -= 0.035;
      
      if (ring.alpha <= 0 || ring.lineWidth <= 0) {
        gameRings.splice(i, 1);
        continue;
      }
      
      ctx.save();
      ctx.globalAlpha = ring.alpha;
      ctx.strokeStyle = ring.color;
      ctx.lineWidth = Math.max(0.5, ring.lineWidth);
      ctx.shadowBlur = 12;
      ctx.shadowColor = ring.color;
      
      ctx.beginPath();
      ctx.arc(ring.x, ring.y, ring.r, 0, Math.PI * 2);
      ctx.stroke();
      ctx.restore();
    }

    for (var i = gameParticles.length - 1; i >= 0; i--) {
      var p = gameParticles[i];
      p.x += p.vx;
      p.y += p.vy;
      p.alpha -= 0.025;
      if (p.alpha <= 0) {
        gameParticles.splice(i, 1);
        continue;
      }
      ctx.save();
      ctx.globalAlpha = p.alpha;
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
      ctx.fillStyle = p.color;
      ctx.shadowColor = p.color;
      ctx.shadowBlur = 6;
      ctx.fill();
      ctx.restore();
    }

    gameAnimationFrameId = requestAnimationFrame(gameLoop);
  }

  gameLoop();
}

function triggerGameVictory() {
  gameActive = false;
  cancelAnimationFrame(gameAnimationFrameId);
  
  playWinSound();

  const canvas = document.getElementById('game-canvas');
  const ctx = canvas.getContext('2d');
  ctx.clearRect(0, 0, canvas.width, canvas.height);

  ctx.font = '65px serif';
  ctx.fillText('🎉', canvas.width / 2 - 32, canvas.height / 2);

  document.getElementById('game-score-display').innerHTML = '🎉 <strong>Sare Tohfe Collect Ho Gaye!</strong> 💖';
  document.getElementById('game-finish-row').style.display = 'flex';
  document.getElementById('game-instructions').style.opacity = '0';
  
  burstParticles();
}

// ===========================
// PHOTO SLIDESHOW (AUTODYNAMIC ASPECT RATIO & ANTI-GLITCH BUFFER)
// ===========================
var viewPhotos = [], photoIdx = 0;
function displayPhotos() {
  if (!giftData) return;
  viewPhotos = giftData.photos || [];
  photoIdx = 0;
  var noPhotoPlaceholder = document.getElementById('no-photo-ph');
  var imgElement = document.getElementById('cur-photo');
  var captionElement = document.getElementById('photo-caption');
  var controllers = document.getElementById('slide-ctrl');

  if (viewPhotos.length > 0) {
    noPhotoPlaceholder.style.display = 'none';
    imgElement.style.display = 'block';
    captionElement.style.display = 'block';
    renderPhoto(0);
    controllers.style.display = viewPhotos.length > 1 ? 'flex' : 'none';
  } else {
    noPhotoPlaceholder.style.display = 'flex';
    imgElement.style.display = 'none';
    captionElement.style.display = 'none';
    controllers.style.display = 'none';
  }
  goTo('s-photos');
}

function renderPhoto(idx) {
  var img = document.getElementById('cur-photo');
  // 1. Softly fade out old image
  img.classList.add('fade-out');
  
  // 2. Preload/Decode offscreen buffer to avoidWebView sizing glitch in mid-flight
  var tempImg = new Image();
  tempImg.onload = function() {
    img.src = tempImg.src;
    // Tiny timeout to let DOM parser recalculate the custom container boundaries cleanly
    setTimeout(function() {
      img.classList.remove('fade-out');
      img.classList.add('fade-in');
      setTimeout(function() { img.classList.remove('fade-in'); }, 400);
    }, 40);
  };
  tempImg.src = viewPhotos[idx];
  
  document.getElementById('photo-count').textContent = (idx + 1) + ' / ' + viewPhotos.length;
}

function prevPhoto() {
  photoIdx = (photoIdx - 1 + viewPhotos.length) % viewPhotos.length;
  renderPhoto(photoIdx);
}

function nextPhoto() {
  photoIdx = (photoIdx + 1) % viewPhotos.length;
  renderPhoto(photoIdx);
}

// ===========================
// WRITER TYPEWRITER SIMULATION
// ===========================
var typingActive = false;
function startLetter() {
  if (!giftData || typingActive) return;
  typingActive = true;
  var headEl = document.getElementById('letter-head');
  headEl.textContent = giftData.receiver + ',';
  document.getElementById('letter-sig').textContent = '— ' + giftData.sender + ' ❤️';
  document.getElementById('letter-sig').classList.remove('show');
  document.getElementById('sig-line').style.opacity = '0';
  document.getElementById('letter-body').innerHTML = '';
  setTimeout(function() { renderText(giftData.letter); }, 900);
}

function renderText(text) {
  var bodyEl = document.getElementById('letter-body');
  var charIdx = 0, currentHTML = '';
  var particleInterval = setInterval(spawnSparkle, 550);

  function write() {
    if (charIdx < text.length) {
      var char = text[charIdx];
      currentHTML += char === '\n' ? '<br>' : char;
      bodyEl.innerHTML = currentHTML + '<span class="cur"></span>';
      charIdx++;
      setTimeout(write, Math.random() * 38 + 26);
    } else {
      clearInterval(particleInterval);
      bodyEl.innerHTML = currentHTML;
      typingActive = false;
      setTimeout(function() {
        document.getElementById('sig-line').style.opacity = '1';
        document.getElementById('letter-sig').classList.add('show');
        setTimeout(showFinalPopup, 2800);
      }, 450);
    }
  }
  write();
}

function spawnSparkle() {
  var wrap = document.getElementById('letter-wrap');
  if (!wrap) return;
  var bounds = wrap.getBoundingClientRect();
  var sp = document.createElement('div');
  sp.className = 'sparkle';
  sp.textContent = ['✨', '⭐', '💫', '🌟', '✦'][Math.floor(Math.random() * 5)];
  Object.assign(sp.style, {
    left: (bounds.left + Math.random() * bounds.width) + 'px',
    top: (bounds.top + Math.random() * bounds.height) + 'px',
    fontSize: (Math.random() * 13 + 9) + 'px'
  });
  document.body.appendChild(sp);
  setTimeout(function() { sp.remove(); }, 950);
}

