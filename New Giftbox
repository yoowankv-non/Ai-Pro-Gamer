}

function closePopup() {
  document.getElementById('popup').classList.remove('show');
}

// ===========================
// PARTICLE ENGINE Burst
// ===========================
function burstParticles() {
  var canvas = document.getElementById('particles-canvas');
  canvas.style.display = 'block';
  canvas.width = window.innerWidth;
  canvas.height = window.innerHeight;
  var ctx = canvas.getContext('2d'), cx = window.innerWidth / 2, cy = window.innerHeight / 2;
  var emojis = ['💗', '💕', '✨', '⭐', '💖', '🌸', '💝'];
  var parts = [];

  for (var i = 0; i < 90; i++) {
    var angle = (Math.PI * 2 * i / 90) + Math.random() * .15;
    var speed = Math.random() * 8 + 2;
    parts.push({
      x: cx, y: cy, vx: Math.cos(angle) * speed, vy: Math.sin(angle) * speed - Math.random() * 2.5,
      r: Math.random() * 6 + 3, g: .14 + Math.random() * .1,
      col: 'hsl(' + (Math.random() * 40 + 325) + ',100%,' + (Math.random() * 25 + 55) + '%)', alpha: 1, type: 'dot'
    });
  }
  for (var i = 0; i < 22; i++) {
    var angle = Math.random() * Math.PI * 2;
    var speed = Math.random() * 6 + 2;
    parts.push({
      x: cx, y: cy, vx: Math.cos(angle) * speed, vy: Math.sin(angle) * speed - Math.random() * 4,
      size: Math.random() * 18 + 10, g: .07, emoji: emojis[Math.floor(Math.random() * emojis.length)],
      alpha: 1, type: 'emoji'
    });
  }

  var tick = 0;
  function updateAndDraw() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    var active = false;
    for (var k = 0; k < parts.length; k++) {
      var p = parts[k];
      if (p.alpha <= .01) continue;
      active = true;
      p.x += p.vx; p.y += p.vy; p.vy += p.g; p.vx *= .98; p.alpha -= .011;
      ctx.globalAlpha = Math.max(0, p.alpha);
      if (p.type === 'emoji') {
        ctx.font = p.size + 'px serif';
        ctx.fillText(p.emoji, p.x, p.y);
      } else {
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.r * p.alpha + .5, 0, Math.PI * 2);
        ctx.fillStyle = p.col;
        ctx.shadowColor = p.col; ctx.shadowBlur = 8;
        ctx.fill(); ctx.shadowBlur = 0;
      }
      ctx.globalAlpha = 1;
    }
    tick++;
    if (active && tick < 220) {
      requestAnimationFrame(updateAndDraw);
    } else {
      canvas.style.display = 'none';
      ctx.clearRect(0, 0, canvas.width, canvas.height);
    }
  }
  updateAndDraw();
}

window.addEventListener('resize', function() {
  var c = document.getElementById('particles-canvas');
  if (c) {
    c.width = window.innerWidth;
    c.height = window.innerHeight;
  }
});

